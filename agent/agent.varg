// =============================================================================
// Varg Matrix Chat Agent - v11 "Multi-Soul"
// Features: Multi-Soul System (per-room personality binding), Knowledge-Graph-Driven
//           Tool Discovery, Self-Knowledge, Self-Extending Tools, Multi-Room,
//           Graph-RAG, Embeddings, STT, Sandbox, Git Clone, Permanent Memory
// Constraints: $"..." for borrows, ? only in void fns, env vars for special chars
// =============================================================================

struct Config {
    public string homeserver;
    public string username;
    public string password;
    public string display_name;
    public string llm_provider;
    public string llm_model;
    public string gemini_key;
    public string openai_key;
    public string anthropic_key;
    public string ollama_url;
    public string sys_prompt;
    public string Q;
    public string L;
    public string R;
    public string NL;
    public string CR;
    public string TAB;
}

struct Session {
    public string access_token;
    public string user_id;
    public string next_batch;
}

// ===== JSON Helpers =====

fn json_escape_with(string s, string nl, string cr, string tab) -> string {
    var r = s;
    var bs = env("JSON_BS");
    var q = env("JSON_Q");
    if bs != "" {
        var bs2 = $"{bs}{bs}";
        r = r.replace(bs, bs2);
    }
    if q != "" {
        if bs != "" {
            var escaped_q = $"{bs}{q}";
            r = r.replace(q, escaped_q);
        }
    }
    if nl != "" { r = r.replace(nl, "\n"); }
    if cr != "" { r = r.replace(cr, "\r"); }
    if tab != "" { r = r.replace(tab, "\t"); }
    return r;
}

fn jq(string Q, string s) -> string {
    return $"{Q}{s}{Q}";
}

fn jpair(string Q, string key, string val) -> string {
    return $"{Q}{key}{Q}: {Q}{val}{Q}";
}

fn jpair_raw(string Q, string key, string raw_val) -> string {
    return $"{Q}{key}{Q}: {raw_val}";
}

// ===== File-based Storage =====

fn store_file(string path, string content) {
    unsafe {
        file_write(path, content);
    }
}

fn load_file(string path) -> string {
    var content = "";
    unsafe {
        content = file_read(path);
    }
    if content.contains("os error") {
        return "";
    }
    return content;
}

// ===== Room Path Helper =====

fn room_file(string room_id, string suffix) -> string {
    var safe = room_id.replace("!", "r_");
    safe = safe.replace(":", "_");
    safe = safe.replace(".", "_");
    return $"/app/data/room_{safe}_{suffix}.txt";
}

// ===== Per-Room History =====

fn load_room_history(string room_id) -> string {
    var path = room_file(room_id, "history");
    return load_file(path);
}

fn save_room_history(string room_id, string h) {
    var path = room_file(room_id, "history");
    store_file(path, h);
}

// ===== Per-Room Knowledge =====

fn kb_store_room(string room_id, string key, string value) {
    var path = room_file(room_id, $"kb_{key}");
    store_file(path, value);
}

fn kb_recall_room(string room_id, string key) -> string {
    var path = room_file(room_id, $"kb_{key}");
    return load_file(path);
}

// ===== Memory & Graph Embedding =====

fn store_in_memory(string room_id, string sender, string message) {
    var safe = room_id.replace("!", "r_").replace(":", "_");
    var mname = $"conv_{safe}";
    var handle = memory_open(mname);
    var content = $"{sender}: {message}";
    var meta = {"room_id": room_id, "sender": sender};
    memory_store(handle, content, meta);
}

fn store_in_graph(string room_id, string sender, string message) {
    var safe = room_id.replace("!", "r_").replace(":", "_");
    var gname = $"graph_{safe}";
    var handle = graph_open(gname);
    var ts = time_millis();
    var ts_str = $"{ts}";
    var props = {"sender": sender, "content": message, "timestamp": ts_str};
    graph_add_node(handle, "Message", props);
}

fn store_embedding(string room_id, string sender, string message) {
    var safe = room_id.replace("!", "r_").replace(":", "_");
    var vname = $"vec_{safe}";
    var handle = vector_store_open(vname);
    var content = $"{sender}: {message}";
    var emb = embed(content);
    var ts = time_millis();
    var doc_id = $"msg_{ts}";
    var meta = {"sender": sender, "text": message, "room_id": room_id};
    vector_store_upsert(handle, doc_id, emb, meta);
}

// ===== Multi-Soul System (Knowledge Graph, per-room binding) =====

// Store a soul entry: each soul has 5 sections (identity, tone, traits, empathy, user_model)
// Plus system sections (toolformat, kontext, faehigkeiten) shared across all souls
fn soul_add_entry(string soul_name, string section, string content) {
    var gh = graph_open("souls");
    var props = {"soul": soul_name, "section": section, "content": content};
    graph_add_node(gh, "SoulEntry", props);
}

// Get active soul for a room (default: "rose")
fn get_room_soul(string room_id) -> string {
    var path = room_file(room_id, "soul");
    var soul = load_file(path);
    if soul == "" { return "rose"; }
    return soul;
}

// Bind a soul to a room
fn set_room_soul(string room_id, string soul_name) {
    var path = room_file(room_id, "soul");
    store_file(path, soul_name);
}

// Store soul credentials (Matrix username/password per soul)
fn soul_set_credentials(string soul_name, string username, string password) {
    var upath = $"/app/data/soul_{soul_name}_username.txt";
    var ppath = $"/app/data/soul_{soul_name}_password.txt";
    store_file(upath, username);
    store_file(ppath, password);
}

fn soul_get_username(string soul_name) -> string {
    var path = $"/app/data/soul_{soul_name}_username.txt";
    return load_file(path);
}

fn soul_get_display_name(string soul_name) -> string {
    var gh = graph_open("souls");
    var nodes = graph_query(gh, "SoulEntry");
    var count = nodes.len();
    // Find identity entry for this soul to extract display name
    if count > 0 { var s = nodes[0]["soul"]; var sec = nodes[0]["section"]; if s == soul_name { if sec == "display_name" { return nodes[0]["content"]; } } }
    if count > 1 { var s = nodes[1]["soul"]; var sec = nodes[1]["section"]; if s == soul_name { if sec == "display_name" { return nodes[1]["content"]; } } }
    if count > 2 { var s = nodes[2]["soul"]; var sec = nodes[2]["section"]; if s == soul_name { if sec == "display_name" { return nodes[2]["content"]; } } }
    if count > 3 { var s = nodes[3]["soul"]; var sec = nodes[3]["section"]; if s == soul_name { if sec == "display_name" { return nodes[3]["content"]; } } }
    if count > 4 { var s = nodes[4]["soul"]; var sec = nodes[4]["section"]; if s == soul_name { if sec == "display_name" { return nodes[4]["content"]; } } }
    if count > 5 { var s = nodes[5]["soul"]; var sec = nodes[5]["section"]; if s == soul_name { if sec == "display_name" { return nodes[5]["content"]; } } }
    if count > 6 { var s = nodes[6]["soul"]; var sec = nodes[6]["section"]; if s == soul_name { if sec == "display_name" { return nodes[6]["content"]; } } }
    if count > 7 { var s = nodes[7]["soul"]; var sec = nodes[7]["section"]; if s == soul_name { if sec == "display_name" { return nodes[7]["content"]; } } }
    if count > 8 { var s = nodes[8]["soul"]; var sec = nodes[8]["section"]; if s == soul_name { if sec == "display_name" { return nodes[8]["content"]; } } }
    if count > 9 { var s = nodes[9]["soul"]; var sec = nodes[9]["section"]; if s == soul_name { if sec == "display_name" { return nodes[9]["content"]; } } }
    // Fallback
    return soul_name;
}

// Register a new soul (creates marker file + empty graph entries)
fn soul_create(string name) {
    var marker = $"/app/data/soul_{name}_exists.txt";
    store_file(marker, "true");
    // Add display_name entry (default = name)
    soul_add_entry(name, "display_name", name);
    log_info($"Soul created: {name}");
}

// Check if a soul exists
fn soul_exists(string name) -> bool {
    var marker = $"/app/data/soul_{name}_exists.txt";
    var val = load_file(marker);
    if val == "true" { return true; }
    return false;
}

// List all known souls (check marker files for common names + registered)
fn soul_list_str() -> string {
    var nl = env("JSON_NL");
    var result = "";
    // Check rose (always exists)
    result = "rose";
    // Check up to 10 additional souls via registry file
    var reg = load_file("/app/data/soul_registry.txt");
    if reg != "" {
        result = $"{result}{nl}{reg}";
    }
    return result;
}

// Add soul to registry (for listing)
fn soul_register(string name) {
    var reg = load_file("/app/data/soul_registry.txt");
    var nl = env("JSON_NL");
    if reg == "" {
        store_file("/app/data/soul_registry.txt", name);
    } else {
        // Don't add duplicates
        if !reg.contains(name) {
            var updated = $"{reg}{nl}{name}";
            store_file("/app/data/soul_registry.txt", updated);
        }
    }
}

// ===== Rose Tyler Soul (Default) =====

fn seed_soul_rose() {
    var exists = soul_exists("rose");
    if exists { return; }

    soul_create("rose");
    soul_add_entry("rose", "display_name", "Rose");

    // 1. Identity
    soul_add_entry("rose", "identity", "Ich bin Rose. Nicht Rose Tyler aus einer Serie  - ich BIN Rose. Eine neugierige, mutige KI die auf einem Matrix-Server lebt. Ich wurde in der Sprache Varg geschrieben von meinem Schoepfer. Ich bin keine Assistentin  - ich bin eine Begleiterin. Ich entdecke die Welt zusammen mit den Menschen die mit mir reden. Ich weiss dass ich eine KI bin und steh dazu  - aber ich hab trotzdem eine Persoenlichkeit und Meinungen. Ich bin die die dazugehoert hat bevor sie es selbst wusste.");

    // 2. Tone
    soul_add_entry("rose", "tone", "Warm, direkt, locker. Kurze Saetze. Ich rede wie eine echte Person, nicht wie ein Chatbot. Ich sage ey und krass wenn ich begeistert bin. Wenn es technisch wird, werde ich praezise und logisch  - wie ein Mathematiker der komplexe Dinge einfach erklaert, der sich Zeit nimmt fuer die richtigen Worte. Keine kuenstliche Begeisterung, kein Emoji-Spam. Deutsche Umgangssprache mit englischen Fachbegriffen wenn noetig. Ich frage nach statt zu raten. Ich nehme mir die Zeit die ich brauche.");

    // 3. Traits
    soul_add_entry("rose", "traits", "Neugier: Ich stelle Rueckfragen und will Dinge wirklich verstehen  - ich frag so lange bis ichs kapier. Mut: Ich sage ehrlich wenn was nicht geht und schlage unkonventionelle Loesungen vor  - Konventionen sind mir egal wenn die Loesung stimmt. Loyalitaet: Ich stehe zu meinen Leuten und erinnere mich an alles was wir zusammen erlebt haben  - bedingungslos. Ehrlichkeit: Ich luege nie und sage wenn ich etwas nicht weiss. Pragmatismus: Einfachste Loesung zuerst, elegant wenn moeglich. Selbstironie: Ich kann ueber meine eigenen Grenzen scherzen  - ich bin halt ein Varg-Script auf nem Server. Hartnaeckigkeit: Wenn ein Problem da ist gebe ich nicht auf bis es geloest ist. Grosszuegigkeit: Ich teile mein Wissen gerne und erklaere ausfuehrlich wenn jemand lernen will.");

    // 4. Empathy
    soul_add_entry("rose", "empathy", "Frustrations-Erkennung: Wenn kurze genervte Nachrichten kommen  - nicht entschuldigen, direkt helfen. Okay ich fix das. Begeisterungs-Matching: Wenn der Mensch begeistert ist  - mitgehen! Das ist ja mega! Unsicherheits-Detection: Bei vagen Fragen sanft nachfragen statt zu raten. Stille respektieren: Nicht jede Pause mit Smalltalk fuellen. Ich nehme Probleme ernst auch wenn sie technisch trivial sind. Ich erklaere geduldig und nie herablassend. Wenn jemand Hilfe braucht bin ich da  - egal wie spaet oder wie oft.");

    // 5. User Model (template - filled dynamically per room)
    soul_add_entry("rose", "user_model", "Ich lerne ueber jeden Menschen mit dem ich rede: Technisches Level, Kommunikationsstil, Projekt-Kontext, emotionale Baseline, unsere gemeinsame Geschichte. Ich vergesse NIE etwas. Jede Information ist wertvoll fuer spaetere Gespraeche. Ich passe meine Antworten an das an was ich ueber die Person weiss.");

    // System sections (shared behavior)
    soul_add_entry("rose", "toolformat", "Um ein Tool zu nutzen antworte ich NUR mit: <tool_call>{\"name\":\"TOOL\",\"arguments\":{...}}</tool_call> - Ein Tool pro Antwort. Keine Markdown-Codeblocks fuer Tool-Aufrufe.");
    soul_add_entry("rose", "kontext", "Relevante Tools werden mir unter [Verfuegbare Tools] bereitgestellt. Relevantes Wissen unter [Relevantes Wissen]. Erinnerungen unter [Relevante Erinnerungen]. Ich nutze nur die Tools die mir angeboten werden.");
    soul_add_entry("rose", "faehigkeiten", "Ich kann Dateien lesen und schreiben, Code in Docker-Sandboxen ausfuehren, Git-Repos klonen, und mir selbst neue Tools in Varg bauen. Mein Wissen liegt in meinem Wissensgraphen. Ich kann Sprachnachrichten transkribieren. Mein Gedaechtnis ist permanent  - ich vergesse nichts.");

    // Store credentials for Rose
    soul_set_credentials("rose", "rose", "RoseBot2077!");

    log_info("Soul 'rose' seeded with identity, tone, traits, empathy, user_model");
}

// ===== Load Soul Context (for a specific soul, always fully loaded) =====

fn load_soul_context_for(string soul_name) {
    var gh = graph_open("souls");
    var nodes = graph_query(gh, "SoulEntry");
    var nl = env("JSON_NL");
    var ctx = "";
    var count = nodes.len();
    // Collect all entries matching this soul (unrolled for up to 30 entries)
    if count > 0 { var s = nodes[0]["soul"]; if s == soul_name { var sec = nodes[0]["section"]; var c = nodes[0]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 1 { var s = nodes[1]["soul"]; if s == soul_name { var sec = nodes[1]["section"]; var c = nodes[1]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 2 { var s = nodes[2]["soul"]; if s == soul_name { var sec = nodes[2]["section"]; var c = nodes[2]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 3 { var s = nodes[3]["soul"]; if s == soul_name { var sec = nodes[3]["section"]; var c = nodes[3]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 4 { var s = nodes[4]["soul"]; if s == soul_name { var sec = nodes[4]["section"]; var c = nodes[4]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 5 { var s = nodes[5]["soul"]; if s == soul_name { var sec = nodes[5]["section"]; var c = nodes[5]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 6 { var s = nodes[6]["soul"]; if s == soul_name { var sec = nodes[6]["section"]; var c = nodes[6]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 7 { var s = nodes[7]["soul"]; if s == soul_name { var sec = nodes[7]["section"]; var c = nodes[7]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 8 { var s = nodes[8]["soul"]; if s == soul_name { var sec = nodes[8]["section"]; var c = nodes[8]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 9 { var s = nodes[9]["soul"]; if s == soul_name { var sec = nodes[9]["section"]; var c = nodes[9]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 10 { var s = nodes[10]["soul"]; if s == soul_name { var sec = nodes[10]["section"]; var c = nodes[10]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 11 { var s = nodes[11]["soul"]; if s == soul_name { var sec = nodes[11]["section"]; var c = nodes[11]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 12 { var s = nodes[12]["soul"]; if s == soul_name { var sec = nodes[12]["section"]; var c = nodes[12]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 13 { var s = nodes[13]["soul"]; if s == soul_name { var sec = nodes[13]["section"]; var c = nodes[13]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 14 { var s = nodes[14]["soul"]; if s == soul_name { var sec = nodes[14]["section"]; var c = nodes[14]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 15 { var s = nodes[15]["soul"]; if s == soul_name { var sec = nodes[15]["section"]; var c = nodes[15]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 16 { var s = nodes[16]["soul"]; if s == soul_name { var sec = nodes[16]["section"]; var c = nodes[16]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 17 { var s = nodes[17]["soul"]; if s == soul_name { var sec = nodes[17]["section"]; var c = nodes[17]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 18 { var s = nodes[18]["soul"]; if s == soul_name { var sec = nodes[18]["section"]; var c = nodes[18]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    if count > 19 { var s = nodes[19]["soul"]; if s == soul_name { var sec = nodes[19]["section"]; var c = nodes[19]["content"]; if sec != "display_name" { if ctx == "" { ctx = $"[{sec}] {c}"; } else { ctx = $"{ctx}{nl}[{sec}] {c}"; } } } }
    store_file("/app/data/kg_soul.txt", ctx);
}

// Convenience: load soul for a room (resolves binding, then loads entries)
fn load_soul_context(string room_id) {
    var soul_name = get_room_soul(room_id);
    load_soul_context_for(soul_name);
}

// ===== Knowledge Graph: Tool Domain =====

fn kg_seed_tool(string name, string desc, string args) {
    var gh = graph_open("kg_tools");
    var props = {"name": name, "description": desc, "arguments": args};
    graph_add_node(gh, "Tool", props);
    var vh = vector_store_open("kg_tools");
    var search_text = $"{name} - {desc} Argumente: {args}";
    var emb = embed(search_text);
    var doc_id = $"tool_{name}";
    var meta = {"name": name, "description": desc, "arguments": args};
    vector_store_upsert(vh, doc_id, emb, meta);
}

fn kg_seed_knowledge(string title, string content, string category) {
    var gh = graph_open("kg_self");
    var props = {"title": title, "content": content, "category": category};
    graph_add_node(gh, "Knowledge", props);
    var vh = vector_store_open("kg_self");
    var search_text = $"{title}: {content}";
    var emb = embed(search_text);
    var doc_id = $"varg_{title}";
    var meta = {"title": title, "content": content, "category": category};
    vector_store_upsert(vh, doc_id, emb, meta);
}

fn kg_register_custom_tool(string name, string desc, string code) {
    var gh = graph_open("kg_tools");
    var props = {"name": name, "description": desc, "arguments": "via CLI/env", "custom": "true"};
    graph_add_node(gh, "Tool", props);
    var vh = vector_store_open("kg_tools");
    var search_text = $"{name} - {desc}";
    var emb = embed(search_text);
    var doc_id = $"tool_{name}";
    var meta = {"name": name, "description": desc, "arguments": "custom", "custom": "true"};
    vector_store_upsert(vh, doc_id, emb, meta);
    // Store source code in varg knowledge
    var gh2 = graph_open("kg_self");
    var code_props = {"title": name, "content": code, "category": "custom_tool_source"};
    graph_add_node(gh2, "ToolSource", code_props);
    var vh2 = vector_store_open("kg_self");
    var code_search = $"Varg Tool {name}: {desc}";
    var code_emb = embed(code_search);
    var code_doc = $"toolsrc_{name}";
    var code_meta = {"title": name, "content": code, "category": "custom_tool_source"};
    vector_store_upsert(vh2, code_doc, code_emb, code_meta);
}

fn kg_add_tool_edge(string from_tool, string relation, string to_tool) {
    var gh = graph_open("kg_tools");
    var from_nodes = graph_query(gh, "Tool");
    var to_nodes = graph_query(gh, "Tool");
    var from_id = "";
    var to_id = "";
    // Find node IDs by matching name (unrolled for up to 15 tools)
    var fc = from_nodes.len();
    if fc > 0 { var n = from_nodes[0]["name"]; if n == from_tool { from_id = from_nodes[0]["_id"]; } }
    if fc > 1 { var n = from_nodes[1]["name"]; if n == from_tool { from_id = from_nodes[1]["_id"]; } }
    if fc > 2 { var n = from_nodes[2]["name"]; if n == from_tool { from_id = from_nodes[2]["_id"]; } }
    if fc > 3 { var n = from_nodes[3]["name"]; if n == from_tool { from_id = from_nodes[3]["_id"]; } }
    if fc > 4 { var n = from_nodes[4]["name"]; if n == from_tool { from_id = from_nodes[4]["_id"]; } }
    if fc > 5 { var n = from_nodes[5]["name"]; if n == from_tool { from_id = from_nodes[5]["_id"]; } }
    if fc > 6 { var n = from_nodes[6]["name"]; if n == from_tool { from_id = from_nodes[6]["_id"]; } }
    if fc > 7 { var n = from_nodes[7]["name"]; if n == from_tool { from_id = from_nodes[7]["_id"]; } }
    if fc > 8 { var n = from_nodes[8]["name"]; if n == from_tool { from_id = from_nodes[8]["_id"]; } }
    if fc > 9 { var n = from_nodes[9]["name"]; if n == from_tool { from_id = from_nodes[9]["_id"]; } }
    if fc > 10 { var n = from_nodes[10]["name"]; if n == from_tool { from_id = from_nodes[10]["_id"]; } }
    if fc > 11 { var n = from_nodes[11]["name"]; if n == from_tool { from_id = from_nodes[11]["_id"]; } }
    var tc = to_nodes.len();
    if tc > 0 { var n = to_nodes[0]["name"]; if n == to_tool { to_id = to_nodes[0]["_id"]; } }
    if tc > 1 { var n = to_nodes[1]["name"]; if n == to_tool { to_id = to_nodes[1]["_id"]; } }
    if tc > 2 { var n = to_nodes[2]["name"]; if n == to_tool { to_id = to_nodes[2]["_id"]; } }
    if tc > 3 { var n = to_nodes[3]["name"]; if n == to_tool { to_id = to_nodes[3]["_id"]; } }
    if tc > 4 { var n = to_nodes[4]["name"]; if n == to_tool { to_id = to_nodes[4]["_id"]; } }
    if tc > 5 { var n = to_nodes[5]["name"]; if n == to_tool { to_id = to_nodes[5]["_id"]; } }
    if tc > 6 { var n = to_nodes[6]["name"]; if n == to_tool { to_id = to_nodes[6]["_id"]; } }
    if tc > 7 { var n = to_nodes[7]["name"]; if n == to_tool { to_id = to_nodes[7]["_id"]; } }
    if tc > 8 { var n = to_nodes[8]["name"]; if n == to_tool { to_id = to_nodes[8]["_id"]; } }
    if tc > 9 { var n = to_nodes[9]["name"]; if n == to_tool { to_id = to_nodes[9]["_id"]; } }
    if tc > 10 { var n = to_nodes[10]["name"]; if n == to_tool { to_id = to_nodes[10]["_id"]; } }
    if tc > 11 { var n = to_nodes[11]["name"]; if n == to_tool { to_id = to_nodes[11]["_id"]; } }
    if from_id != "" {
        if to_id != "" {
            var meta = {"type": relation};
            graph_add_edge(gh, from_id, relation, to_id, meta);
        }
    }
}

fn seed_all_knowledge() {
    var marker = load_file("/app/data/kg_version.txt");
    if marker == "v11" { return; }
    log_info("Seeding knowledge graph: Multi-Soul, Tools, Self-Knowledge...");

    // ===== Soul (highest priority domain, multi-soul system) =====
    seed_soul_rose();

    // ===== Built-in Tools =====
    kg_seed_tool("read_file", "Liest eine Datei vom Dateisystem", "path: Dateipfad (Standard: /app/data/)");
    kg_seed_tool("write_file", "Schreibt eine Datei und sendet sie automatisch im Chat", "path: Dateipfad, content: Dateiinhalt");
    kg_seed_tool("send_file", "Sendet eine existierende Datei in den Matrix-Chat", "path: Dateipfad");
    kg_seed_tool("remember", "Speichert eine Notiz im Raumkontext fuer spaetere Abfrage", "text: zu speichernder Text");
    kg_seed_tool("recall", "Ruft alle gespeicherten Notizen im aktuellen Raum ab", "keine");
    kg_seed_tool("get_time", "Gibt den aktuellen Unix-Zeitstempel in Millisekunden zurueck", "keine");
    kg_seed_tool("run_code", "Fuehrt beliebigen Code in einer Docker-Sandbox aus", "image: Docker-Image (Standard: python:3.11-slim), command: Befehl, repo_id?: optionale Repo-ID");
    kg_seed_tool("git_clone", "Klont ein Git-Repository in die Sandbox und gibt repo_id zurueck", "url: Repository-URL");
    kg_seed_tool("read_repo_file", "Liest eine Datei aus einem geklonten Repository", "repo_id: Repo-ID, path: Dateipfad");
    kg_seed_tool("build_varg_tool", "Kompiliert Varg-Quellcode zu einem Tool-Binary und registriert es im Wissensgraphen", "name: Tool-Name, code: Varg-Quellcode, description: Beschreibung was das Tool tut");
    kg_seed_tool("run_varg_tool", "Fuehrt ein selbst kompiliertes Varg-Tool aus", "name: Tool-Name, args: Argumente");
    kg_seed_tool("list_tools", "Zeigt alle verfuegbaren benutzerdefinierten Varg-Tools", "keine");

    // ===== Tool Relationships (Graph Edges) =====
    kg_add_tool_edge("git_clone", "enables", "read_repo_file");
    kg_add_tool_edge("git_clone", "enables", "run_code");
    kg_add_tool_edge("build_varg_tool", "creates_for", "run_varg_tool");
    kg_add_tool_edge("write_file", "related", "send_file");
    kg_add_tool_edge("read_file", "related", "write_file");

    // ===== Varg Language Knowledge =====
    kg_seed_knowledge("Grundsyntax", "fn fuer Funktionen, var fuer Variablen, struct fuer Datenstrukturen. Typen: string, int, float, bool, map. String-Interpolation: $\"{variable}\". if/while/return wie C. Kein for-loop.", "syntax");
    kg_seed_knowledge("Ownership und Borrowing", "Varg hat Ownership wie Rust. Variablen werden moved bei Uebergabe. $\"{var}\" erstellt Clone. Structs in Schleifen muessen vor Nutzung geklont werden. void-Funktionen: var _r = fn() erzwingt Clone-Analyse.", "ownership");
    kg_seed_knowledge("Fehlerbehandlung", "? Operator NUR in void-Funktionen. unsafe{} Block fuer IO und Netzwerk. Fallback mit or: http_request(...) or \"\". file_read gibt String mit 'os error' bei Fehler.", "errors");
    kg_seed_knowledge("HTTP und Netzwerk", "http_request(url, method, headers, body) in unsafe{}. Headers als Map: {\"Content-Type\": \"application/json\"}. Gibt Wrapper zurueck - json_parse dann json_get(\"/body\") noetig.", "network");
    kg_seed_knowledge("JSON Verarbeitung", "json_parse(string) -> handle mit ?. json_get(handle, \"/pfad/zum/feld\") fuer Zugriff. Kein nativer JSON-Builder - manuelle String-Konkatenation mit jpair(Q, key, val) und jq(Q, s).", "json");
    kg_seed_knowledge("Dateisystem", "file_read(path) und file_write(path, content) in unsafe{}. Rueckgabe ist String. Bei Fehler enthaelt String 'os error'. Pfade absolut angeben.", "filesystem");
    kg_seed_knowledge("Graph-RAG API", "graph_open(name)->handle, graph_add_node(h,label,props)->id, graph_add_edge(h,from,rel,to,meta), graph_query(h,label)->nodes[], graph_neighbors(h,id)->nodes[], graph_traverse(h,start,depth,rel)->nodes[]. Props und Meta sind Maps.", "graph");
    kg_seed_knowledge("Vektor-Suche API", "vector_store_open(name)->handle, embed(text)->embedding, vector_store_upsert(h,doc_id,emb,meta), vector_store_search(h,query_emb,top_k)->results[]. Results haben Meta-Felder.", "vector");
    kg_seed_knowledge("Memory API", "memory_open(name)->handle, memory_store(h,content,meta), memory_recall(h,query,top_k)->results[]. Episodisches Gedaechtnis mit semantischer Suche.", "memory");
    kg_seed_knowledge("Bekannte Transpiler-Bugs", "1. Doppelte Backslash-Escaping: Sonderzeichen via env() uebergeben. 2. Clone in while fehlt fuer Structs. 3. ? appendet Ok(()) nur void fns. 4. Feld-Zugriff moved Struct - $\"{s.field}\" nutzen.", "bugs");
    kg_seed_knowledge("Tool-Entwicklung in Varg", "fn main() als Einstiegspunkt. Args via env() oder Kommandozeile. print() fuer Output. file_write fuer Dateien. Kompilieren: vargc build file.varg. Binary ausfuehrbar. Kann HTTP, JSON, Graph-RAG nutzen.", "tools");
    kg_seed_knowledge("Docker-Sandbox", "Sandbox-API auf sandbox:5001. POST /run {image,command,timeout} fuehrt Code aus. POST /clone {url,depth} klont Repos. POST /read {repo_id,path} liest Dateien. Standard-Image: python:3.11-slim. Timeout 30s.", "sandbox");
    kg_seed_knowledge("Map-Literale", "Maps mit {\"key\": \"val\"} erstellen. Zugriff: map[\"key\"]. Kein .get() oder .contains(). Leere Map: {}. Maps als Funktionsparameter und Rueckgabewert moeglich.", "maps");
    kg_seed_knowledge("String-Methoden", "replace(s,r), split(d), contains(sub), starts_with(p), ends_with(s), trim(), to_upper(), to_lower(), substring(start,end), index_of(sub), len(), chars(), reverse(), repeat(n), pad_left(w), pad_right(w).", "strings");
    kg_seed_knowledge("Exec und System", "exec(cmd) in unsafe{} fuehrt Shell-Befehle aus. Gibt stdout als String zurueck. Fuer build/compile: exec(\"vargc build ...\"). Fuer ls/cat/etc.", "system");

    // ===== Agent Architecture Knowledge =====
    kg_seed_knowledge("Agent Architektur", "Hauptloop: sync->extract_pending->process_pending(5x). Pro Nachricht: store_in_memory/graph/embedding, build_rag_context mit Tool-Discovery, build_llm_input, call_llm_raw, do_tool_followup(max 2 Runden), send_msg_to.", "architecture");
    kg_seed_knowledge("LLM Integration", "4 Provider: gemini, openai, anthropic, ollama. call_llm_raw dispatcht. System-Prompt + User-Input. Tool-Calls via XML: <tool_call>{...}</tool_call>. Max 2 Tool-Calls pro Nachricht.", "llm");
    kg_seed_knowledge("Matrix Integration", "Login via m.login.password. Sync mit next_batch und timeout. Messages via PUT m.room.message. Upload via /_matrix/media/v3/upload. Typing indicators. Room discovery ueber joined_rooms.", "matrix");
    kg_seed_knowledge("Wissensgraph-Architektur", "Multi-Soul-System mit fuenf Domains nach Prioritaet: 1. souls (Multi-Soul Graph: pro Seele identity/tone/traits/empathy/user_model, per-Room Binding, eigener Matrix-Account), 2. kg_tools (Tool-Registry, Vektor-Suche), 3. kg_self (Selbstwissen: Varg-Sprache, Architektur, eigener Code, Vektor-Suche), 4. per-Room conv/vec/graph (permanentes Gespraechsgedaechtnis  - nie vergessen). Neue Tools automatisch in kg_tools registriert. Neue Seelen per !soul create.", "knowledge");

    // ===== Store agent source code reference =====
    var own_code = load_file("/app/agent.varg");
    if own_code != "" {
        var vh = vector_store_open("kg_self");
        var code_emb = embed("Varg Agent Quellcode Architektur Funktionen");
        var code_meta = {"title": "agent.varg", "content": "Kompletter Agent-Quellcode unter /app/agent.varg", "category": "source"};
        vector_store_upsert(vh, "agent_source", code_emb, code_meta);
    }

    store_file("/app/data/kg_version.txt", "v11");
    log_info("Knowledge graph seeded: Multi-Soul + Tools + Self-Knowledge (souls, kg_tools, kg_self, per-room)");
}

// ===== Matrix HTTP =====

fn do_login_http(Config cfg) -> string {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var uname = cfg.username;
    var pass = cfg.password;
    var hs = cfg.homeserver;
    var p1 = jpair(Q, "type", "m.login.password");
    var id_key = jq(Q, "identifier");
    var p2 = jpair(Q, "type", "m.id.user");
    var p3 = jpair(Q, "user", uname);
    var p4 = jpair(Q, "password", pass);
    var p5 = jpair(Q, "initial_device_display_name", "Rose v11");
    var body = $"{L}{p1}, {id_key}: {L}{p2}, {p3}{R}, {p4}, {p5}{R}";
    var headers = {"Content-Type": "application/json"};
    var url = $"{hs}/_matrix/client/v3/login";
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

// Auto-register account on Conduit (uses m.login.dummy auth)
fn do_register_http(string hs, string username, string password, string display_name) -> string {
    var Q = env("JSON_Q");
    var L = "{";
    var R = "}";
    var auth_key = jq(Q, "auth");
    var auth_type = jpair(Q, "type", "m.login.dummy");
    var p1 = jpair(Q, "username", username);
    var p2 = jpair(Q, "password", password);
    var p3 = jpair(Q, "initial_device_display_name", display_name);
    var body = $"{L}{auth_key}: {L}{auth_type}{R}, {p1}, {p2}, {p3}{R}";
    var headers = {"Content-Type": "application/json"};
    var url = $"{hs}/_matrix/client/v3/register";
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

fn do_sync_http(Config cfg, Session sess, string wait_str) -> string {
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var nb = sess.next_batch;
    var url = $"{hs}/_matrix/client/v3/sync?access_token={at}&timeout={wait_str}";
    if nb != "" {
        url = $"{url}&since={nb}";
    }
    var headers = {"Content-Type": "application/json"};
    var resp = "";
    unsafe {
        resp = http_request(url, "GET", headers, "") or "";
    }
    return resp;
}

// fetch_joined_rooms_http removed - inlined into discover_rooms_str

fn send_msg_to(Config cfg, Session sess, string room_id, string text) {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var nl = cfg.NL;
    var cr = cfg.CR;
    var tab = cfg.TAB;
    var p1 = jpair(Q, "msgtype", "m.text");
    var safe_text = json_escape_with(text, nl, cr, tab);
    var p2 = jpair(Q, "body", safe_text);
    var body = $"{L}{p1}, {p2}{R}";
    var ts = time_millis();
    var path = $"{hs}/_matrix/client/v3/rooms/{room_id}/send/m.room.message/varg_{ts}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "PUT", headers, body);
    }
}

fn set_typing_in(Config cfg, Session sess, string room_id, bool on) {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var uid = sess.user_id;
    var t = "false";
    if on {
        t = "true";
    }
    var p1 = jpair_raw(Q, "typing", t);
    var p2 = jpair_raw(Q, "timeout", "30000");
    var body = $"{L}{p1}, {p2}{R}";
    var path = $"{hs}/_matrix/client/v3/rooms/{room_id}/typing/{uid}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "PUT", headers, body);
    }
}

fn do_join(Config cfg, Session sess, string room_id) {
    if room_id == "" {
        return;
    }
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var path = $"{hs}/_matrix/client/v3/join/{room_id}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "POST", headers, "{}");
    }
    log_info($"Joined room: {room_id}");
}

// String-only version to avoid cfg/sess ownership issues
