fn send_image_to_room(string hs, string at, string room_id, string filename, string mxc_uri) {
    var Q = env("JSON_Q");
    var L = "{";
    var R = "}";
    var p1 = jpair(Q, "msgtype", "m.image");
    var p2 = jpair(Q, "body", filename);
    var p3 = jpair(Q, "url", mxc_uri);
    var info_key = jq(Q, "info");
    var mime = jpair(Q, "mimetype", "image/png");
    var body = $"{L}{p1}, {p2}, {p3}, {info_key}: {L}{mime}{R}{R}";
    var ts = time_millis();
    var path = $"{hs}/_matrix/client/v3/rooms/{room_id}/send/m.room.message/varg_img_{ts}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "PUT", headers, body);
    }
}

fn send_read_receipt(string hs, string at, string room_id, string event_id) {
    var path = $"{hs}/_matrix/client/v3/rooms/{room_id}/receipt/m.read/{event_id}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "POST", headers, "{}") or "";
    }
}

// String-only sync to avoid cfg/sess consumption in main loop
fn do_sync_str(string hs, string at, string nb, string wait_str) -> string {
    var url = $"{hs}/_matrix/client/v3/sync?access_token={at}&timeout={wait_str}";
    if nb != "" {
        url = $"{url}&since={nb}";
    }
    var headers = {"Content-Type": "application/json"};
    var resp = "";
    unsafe {
        resp = http_request(url, "GET", headers, "") or "";
    }
    return resp;
}

fn set_display(Config cfg, Session sess) {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var dn = cfg.display_name;
    var hs = cfg.homeserver;
    var uid = sess.user_id;
    var at = sess.access_token;
    var pair = jpair(Q, "displayname", dn);
    var body = $"{L}{pair}{R}";
    var path = $"{hs}/_matrix/client/v3/profile/{uid}/displayname?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "PUT", headers, body);
    }
}

// ===== Room Discovery (takes strings, no cfg/sess) =====

fn discover_rooms_str(string hs, string at) {
    var url = $"{hs}/_matrix/client/v3/joined_rooms?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    var resp = "";
    unsafe {
        resp = http_request(url, "GET", headers, "") or "";
    }
    if resp == "" {
        return;
    }
    var wrap = json_parse(resp)?;
    var body_str = json_get(wrap, "/body");
    if body_str == "" {
        return;
    }
    var parsed = json_parse(body_str)?;
    var i = 0;
    while i < 50 {
        var path = $"/joined_rooms/{i}";
        var rid = json_get(parsed, path);
        if rid == "" {
            break;
        }
        var fpath = $"/app/data/joined_room_{i}.txt";
        store_file(fpath, rid);
        i = i + 1;
    }
    var count_str = $"{i}";
    store_file("/app/data/joined_room_count.txt", count_str);
}

// ===== Invite Detection (stores to file, no joining) =====

fn find_invites_in_body(string body_str) {
    var Q = env("JSON_Q");
    if Q == "" { return; }
    var L = "{";
    var pattern = $"invite{Q}:{L}{Q}!";
    if !body_str.contains(pattern) { return; }

    // Replace pattern with unique marker (avoids index_of byte/char mismatch)
    var work = body_str.replace(pattern, "ZZINVZZ");
    // work = ...ZZINVZZ<room_id_without_bang>":{...

    // Scan char-by-char for the marker (consistent char positions)
    var pos = 0;
    while pos < 50000 {
        var seven = work.substring(pos, 7);
        if seven == "ZZINVZZ" {
            // Found marker! Room ID (without !) starts at pos+7
            var room_rest = work.substring(pos + 7, 200);
            if room_rest.contains(Q) {
                var q_pos = room_rest.index_of(Q);
                // room_rest is short + ASCII-only, so byte/char match here
                var room_no_bang = room_rest.substring(0, q_pos);
                var room_id = $"!{room_no_bang}";
                log_info($"Found invite: {room_id}");
                store_file("/app/data/invited_room.txt", room_id);
            }
            return;
        }
        pos = pos + 1;
    }
}

// ===== LLM Providers =====

fn call_gemini_http(Config cfg, string user_prompt) -> string {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var nl = cfg.NL;
    var cr = cfg.CR;
    var tab = cfg.TAB;
    var sp = cfg.sys_prompt;
    var model = cfg.llm_model;
    if model == "" { model = "gemini-2.5-flash"; }
    var gk = cfg.gemini_key;
    var url = $"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={gk}";
    var c_key = jq(Q, "contents");
    var r_pair = jpair(Q, "role", "user");
    var p_key = jq(Q, "parts");
    var safe_msg = json_escape_with(user_prompt, nl, cr, tab);
    var t_pair = jpair(Q, "text", safe_msg);
    var si_key = jq(Q, "systemInstruction");
    var safe_sp = json_escape_with(sp, nl, cr, tab);
    var sp_pair = jpair(Q, "text", safe_sp);
    var body = $"{L}{c_key}: [{L}{r_pair}, {p_key}: [{L}{t_pair}{R}]{R}], {si_key}: {L}{p_key}: [{L}{sp_pair}{R}]{R}{R}";
    var headers = {"Content-Type": "application/json"};
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

fn call_openai_http(Config cfg, string user_prompt) -> string {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var nl = cfg.NL;
    var cr = cfg.CR;
    var tab = cfg.TAB;
    var sp = cfg.sys_prompt;
    var model = cfg.llm_model;
    if model == "" { model = "gpt-4o"; }
    var okey = cfg.openai_key;
    var url = "https://api.openai.com/v1/chat/completions";
    var custom_url = $"{cfg.ollama_url}";
    if custom_url.starts_with("http") {
        url = custom_url;
    }
    var safe_msg = json_escape_with(user_prompt, nl, cr, tab);
    var safe_sp = json_escape_with(sp, nl, cr, tab);
    var m_pair = jpair(Q, "model", model);
    var msg_key = jq(Q, "messages");
    var sys_role = jpair(Q, "role", "system");
    var sys_content = jpair(Q, "content", safe_sp);
    var usr_role = jpair(Q, "role", "user");
    var usr_content = jpair(Q, "content", safe_msg);
    var body = $"{L}{m_pair}, {msg_key}: [{L}{sys_role}, {sys_content}{R}, {L}{usr_role}, {usr_content}{R}]{R}";
    var auth = $"Bearer {okey}";
    var headers = {"Content-Type": "application/json", "Authorization": auth};
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

fn call_anthropic_http(Config cfg, string user_prompt) -> string {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var nl = cfg.NL;
    var cr = cfg.CR;
    var tab = cfg.TAB;
    var sp = cfg.sys_prompt;
    var model = cfg.llm_model;
    if model == "" { model = "claude-sonnet-4-20250514"; }
    var akey = cfg.anthropic_key;
    var url = "https://api.anthropic.com/v1/messages";
    var safe_msg = json_escape_with(user_prompt, nl, cr, tab);
    var safe_sp = json_escape_with(sp, nl, cr, tab);
    var m_pair = jpair(Q, "model", model);
    var mt_pair = jpair_raw(Q, "max_tokens", "4096");
    var sys_pair = jpair(Q, "system", safe_sp);
    var msg_key = jq(Q, "messages");
    var usr_role = jpair(Q, "role", "user");
    var usr_content = jpair(Q, "content", safe_msg);
    var body = $"{L}{m_pair}, {mt_pair}, {sys_pair}, {msg_key}: [{L}{usr_role}, {usr_content}{R}]{R}";
    var headers = {"Content-Type": "application/json", "x-api-key": akey, "anthropic-version": "2023-06-01"};
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

fn call_ollama_http(Config cfg, string user_prompt) -> string {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var nl = cfg.NL;
    var cr = cfg.CR;
    var tab = cfg.TAB;
    var sp = cfg.sys_prompt;
    var model = cfg.llm_model;
    if model == "" { model = "llama3"; }
    var oll_url = cfg.ollama_url;
    var url = $"{oll_url}/api/chat";
    var safe_msg = json_escape_with(user_prompt, nl, cr, tab);
    var safe_sp = json_escape_with(sp, nl, cr, tab);
    var m_pair = jpair(Q, "model", model);
    var msg_key = jq(Q, "messages");
    var sys_role = jpair(Q, "role", "system");
    var sys_content = jpair(Q, "content", safe_sp);
    var usr_role = jpair(Q, "role", "user");
    var usr_content = jpair(Q, "content", safe_msg);
    var nostr_pair = jpair_raw(Q, "stream", "false");
    var body = $"{L}{m_pair}, {msg_key}: [{L}{sys_role}, {sys_content}{R}, {L}{usr_role}, {usr_content}{R}], {nostr_pair}{R}";
    var headers = {"Content-Type": "application/json"};
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

fn is_rate_limited(string resp) -> bool {
    if resp == "" { return false; }
    if resp.contains("Resource exhausted") { return true; }
    if resp.contains("429") {
        if resp.contains("RESOURCE_EXHAUSTED") { return true; }
        if resp.contains("Too Many Requests") { return true; }
        if resp.contains("rate limit") { return true; }
    }
    return false;
}

fn call_llm_once(Config cfg, string user_prompt) -> string {
    var provider = $"{cfg.llm_provider}";
    if provider == "gemini" {
        return call_gemini_http(cfg, user_prompt);
    }
    if provider == "openai" {
        return call_openai_http(cfg, user_prompt);
    }
    if provider == "anthropic" {
        return call_anthropic_http(cfg, user_prompt);
    }
    if provider == "ollama" {
        return call_ollama_http(cfg, user_prompt);
    }
    return "";
}

fn call_llm_raw(Config cfg, string user_prompt) -> string {
    // Attempt 1
    var resp = call_llm_once(cfg, user_prompt);
    if resp != "" {
        if !is_rate_limited(resp) {
            return resp;
        }
        log_info("[RATE_LIMIT] Attempt 1 rate-limited, short pause then retry...");
        sleep(500);
    }
    // Attempt 2
    var resp2 = call_llm_once(cfg, user_prompt);
    if resp2 != "" {
        if !is_rate_limited(resp2) {
            return resp2;
        }
        log_info("[RATE_LIMIT] Attempt 2 rate-limited, returning as-is");
    }
    // Return whatever we got (even if rate-limited, let caller handle)
    if resp2 != "" { return resp2; }
    return resp;
}

// ===== Response Extraction (void - uses ?) =====

fn extract_and_send_to(Config cfg, Session sess, string room_id, string raw_resp) {
    var wrap = json_parse(raw_resp)?;
    var body_str = json_get(wrap, "/body");
    var parsed = json_parse(body_str)?;

    var provider = $"{cfg.llm_provider}";
    var reply = "";

    if provider == "gemini" {
        reply = json_get(parsed, "/candidates/0/content/parts/0/text");
    }
    if provider == "openai" {
        reply = json_get(parsed, "/choices/0/message/content");
    }
    if provider == "anthropic" {
        reply = json_get(parsed, "/content/0/text");
    }
    if provider == "ollama" {
        reply = json_get(parsed, "/message/content");
    }

    if reply == "" {
        var err = json_get(parsed, "/error/message");
        if err != "" {
            reply = $"LLM Error: {err}";
        } else {
            reply = "Error: could not parse LLM response";
        }
    }

    send_msg_to(cfg, sess, room_id, reply);

    // Save reply to per-room temp file for history tracking
    var reply_file = room_file(room_id, "last_reply");
    store_file(reply_file, reply);
}

// ===== LLM Reply Extraction (to file, no send) =====

fn extract_llm_reply(Config cfg, string raw_resp) {
    var wrap = json_parse(raw_resp)?;
    var body_str = json_get(wrap, "/body");
    var parsed = json_parse(body_str)?;
    var provider = $"{cfg.llm_provider}";
    var reply = "";
    if provider == "gemini" {
        reply = json_get(parsed, "/candidates/0/content/parts/0/text");
    }
    if provider == "openai" {
        reply = json_get(parsed, "/choices/0/message/content");
    }
    if provider == "anthropic" {
        reply = json_get(parsed, "/content/0/text");
    }
    if provider == "ollama" {
        reply = json_get(parsed, "/message/content");
    }
    if reply == "" {
        var err = json_get(parsed, "/error/message");
        var err_check = $"{err}";
        if err != "" {
            if is_rate_limited(err_check) {
                reply = "Moment, ich bin gerade etwas ueberlastet. Versuch es bitte gleich nochmal!";
                log_info($"[RATE_LIMIT] LLM rate limited: {err}");
            } else {
                reply = $"LLM Error: {err}";
            }
        } else {
            // Check raw body for rate limit indicators
            if is_rate_limited(body_str) {
                reply = "Moment, ich bin gerade etwas ueberlastet. Versuch es bitte gleich nochmal!";
                log_info("[RATE_LIMIT] LLM rate limited (detected in body)");
            } else {
                reply = "Error: could not parse LLM response";
            }
        }
    }
    store_file("/app/data/llm_reply.txt", reply);
}

// ===== Graph-RAG Retrieval =====

// Recall episodic memory (void fn for ? operator, stores to file)
fn recall_memory_context(string room_id, string search_text) {
    var safe = room_id.replace("!", "r_").replace(":", "_");
    var mname = $"conv_{safe}";
    var handle = memory_open(mname);
    var results = memory_recall(handle, search_text, 3);
    var nl = env("JSON_NL");
    var ctx = "";
    var count = results.len();
    if count > 0 {
        var item0 = results[0]["_content"];
        ctx = $"{item0}";
    }
    if count > 1 {
        var item1 = results[1]["_content"];
        ctx = $"{ctx}{nl}{item1}";
    }
    if count > 2 {
        var item2 = results[2]["_content"];
        ctx = $"{ctx}{nl}{item2}";
    }
    store_file("/app/data/rag_memory.txt", ctx);
}

// Search vector store for semantically similar past messages
fn search_vector_context(string room_id, string search_text) {
    var safe = room_id.replace("!", "r_").replace(":", "_");
    var vname = $"vec_{safe}";
    var handle = vector_store_open(vname);
    var query_emb = embed(search_text);
    var results = vector_store_search(handle, query_emb, 3);
    var nl = env("JSON_NL");
    var ctx = "";
    var count = results.len();
    if count > 0 {
        var item0 = results[0]["text"];
        ctx = $"{item0}";
    }
    if count > 1 {
        var item1 = results[1]["text"];
        ctx = $"{ctx}{nl}{item1}";
    }
    if count > 2 {
        var item2 = results[2]["text"];
        ctx = $"{ctx}{nl}{item2}";
    }
    store_file("/app/data/rag_vector.txt", ctx);
}

// Query graph for related message nodes and traverse connections
fn search_graph_context(string room_id, string search_text) {
    var safe = room_id.replace("!", "r_").replace(":", "_");
    var gname = $"graph_{safe}";
    var handle = graph_open(gname);
    // Get all Message nodes
    var nodes = graph_query(handle, "Message");
    var nl = env("JSON_NL");
    var ctx = "";
    var count = nodes.len();
    if count > 0 {
        var n0 = nodes[0];
        var content0 = n0["content"];
        if content0 != "" { ctx = $"{content0}"; }
    }
    if count > 1 {
        var n1 = nodes[1];
        var content1 = n1["content"];
        if content1 != "" { ctx = $"{ctx}{nl}{content1}"; }
    }
    if count > 2 {
        var n2 = nodes[2];
        var content2 = n2["content"];
        if content2 != "" { ctx = $"{ctx}{nl}{content2}"; }
    }
    store_file("/app/data/rag_graph.txt", ctx);
}

// ===== Knowledge Discovery (Dynamic Tool & Knowledge Retrieval) =====

fn is_capability_question(string msg) -> bool {
    var m = msg.to_lower();
    if m.contains("was kannst du") { return true; }
    if m.contains("was kannst") { return true; }
    if m.contains("welche tools") { return true; }
    if m.contains("welche funktionen") { return true; }
    if m.contains("was sind deine") { return true; }
    if m.contains("zeig mir deine") { return true; }
    if m.contains("liste deine") { return true; }
    if m.contains("all deine") { return true; }
    if m.contains("alle tools") { return true; }
    if m.contains("what can you") { return true; }
    if m.contains("your tools") { return true; }
    if m.contains("your capabilities") { return true; }
    // Explicit tool name mentions -> load all so LLM can use the named tool
    if m.contains("rufe") { if m.contains("tool") { return true; } }
    if m.contains("nutze") { if m.contains("tool") { return true; } }
    if m.contains("benutze") { if m.contains("tool") { return true; } }
    if m.contains("use the") { if m.contains("tool") { return true; } }
    if m.contains("call the") { if m.contains("tool") { return true; } }
    if m.contains("generate_pdf") { return true; }
    if m.contains("run the") { return true; }
    return false;
}

