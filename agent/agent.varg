    kg_add_tool_edge("convert_to_pdf", "related", "generate_pdf");
    kg_add_tool_edge("calendar_list", "related", "calendar_create");
    kg_add_tool_edge("calendar_create", "related", "set_reminder");
    kg_add_tool_edge("update_soul", "related", "remember");

    // ===== Varg Language Knowledge =====
    kg_seed_knowledge("Grundsyntax", "fn fuer Funktionen, var fuer Variablen, struct fuer Datenstrukturen. Typen: string, int, float, bool, map. String-Interpolation: $\"{variable}\". if/while/return wie C. Kein for-loop.", "syntax");
    kg_seed_knowledge("Ownership und Borrowing", "Varg hat Ownership wie Rust. Variablen werden moved bei Uebergabe. $\"{var}\" erstellt Clone. Structs in Schleifen muessen vor Nutzung geklont werden. void-Funktionen: var _r = fn() erzwingt Clone-Analyse.", "ownership");
    kg_seed_knowledge("Fehlerbehandlung", "? Operator NUR in void-Funktionen. unsafe{} Block fuer IO und Netzwerk. Fallback mit or: http_request(...) or \"\". file_read gibt String mit 'os error' bei Fehler.", "errors");
    kg_seed_knowledge("HTTP und Netzwerk", "http_request(url, method, headers, body) in unsafe{}. Headers als Map: {\"Content-Type\": \"application/json\"}. Gibt Wrapper zurueck - json_parse dann json_get(\"/body\") noetig.", "network");
    kg_seed_knowledge("JSON Verarbeitung", "json_parse(string) -> handle mit ?. json_get(handle, \"/pfad/zum/feld\") fuer Zugriff. Kein nativer JSON-Builder - manuelle String-Konkatenation mit jpair(Q, key, val) und jq(Q, s).", "json");
    kg_seed_knowledge("Dateisystem", "file_read(path) und file_write(path, content) in unsafe{}. Rueckgabe ist String. Bei Fehler enthaelt String 'os error'. Pfade absolut angeben.", "filesystem");
    kg_seed_knowledge("Graph-RAG API", "graph_open(name)->handle, graph_add_node(h,label,props)->id, graph_add_edge(h,from,rel,to,meta), graph_query(h,label)->nodes[], graph_neighbors(h,id)->nodes[], graph_traverse(h,start,depth,rel)->nodes[]. Props und Meta sind Maps.", "graph");
    kg_seed_knowledge("Vektor-Suche API", "vector_store_open(name)->handle, embed(text)->embedding, vector_store_upsert(h,doc_id,emb,meta), vector_store_search(h,query_emb,top_k)->results[]. Results haben Meta-Felder.", "vector");
    kg_seed_knowledge("Memory API", "memory_open(name)->handle, memory_store(h,content,meta), memory_recall(h,query,top_k)->results[]. Episodisches Gedaechtnis mit semantischer Suche.", "memory");
    kg_seed_knowledge("Bekannte Transpiler-Bugs", "1. Doppelte Backslash-Escaping: Sonderzeichen via env() uebergeben. 2. Clone in while fehlt fuer Structs. 3. ? appendet Ok(()) nur void fns. 4. Feld-Zugriff moved Struct - $\"{s.field}\" nutzen.", "bugs");
    kg_seed_knowledge("Tool-Entwicklung in Varg", "fn main() als Einstiegspunkt. Args via env() oder Kommandozeile. print() fuer Output. file_write fuer Dateien. Kompilieren: vargc build file.varg. Binary ausfuehrbar. Kann HTTP, JSON, Graph-RAG nutzen.", "tools");
    kg_seed_knowledge("Docker-Sandbox", "Sandbox-API auf sandbox:5001. POST /run {image,command,timeout} fuehrt Code aus. POST /clone {url,depth} klont Repos. POST /read {repo_id,path} liest Dateien. Standard-Image: python:3.11-slim. Timeout 30s.", "sandbox");
    kg_seed_knowledge("Map-Literale", "Maps mit {\"key\": \"val\"} erstellen. Zugriff: map[\"key\"]. Kein .get() oder .contains(). Leere Map: {}. Maps als Funktionsparameter und Rueckgabewert moeglich.", "maps");
    kg_seed_knowledge("String-Methoden", "replace(s,r), split(d), contains(sub), starts_with(p), ends_with(s), trim(), to_upper(), to_lower(), substring(start,end), index_of(sub), len(), chars(), reverse(), repeat(n), pad_left(w), pad_right(w).", "strings");
    kg_seed_knowledge("Exec und System", "exec(cmd) in unsafe{} fuehrt Shell-Befehle aus. Gibt stdout als String zurueck. Fuer build/compile: exec(\"vargc build ...\"). Fuer ls/cat/etc.", "system");

    // ===== Agent Architecture Knowledge =====
    kg_seed_knowledge("Agent Architektur", "Hauptloop: sync dann extract_pending dann process_pending(5x). Pro Nachricht: speichern in memory und graph, RAG-Kontext bauen mit Tool-Discovery, LLM aufrufen, Tool-Followup(max 2 Runden), Antwort senden.", "architecture");
    kg_seed_knowledge("LLM Integration", "4 Provider: gemini, openai, anthropic, ollama. Dispatch nach Provider. System-Prompt plus User-Input. Tool-Aufrufe via XML-Tags. Max 2 Tool-Aufrufe pro Nachricht.", "llm");
    kg_seed_knowledge("Matrix Integration", "Login via m.login.password. Sync mit next_batch und timeout. Messages via PUT m.room.message. Upload via /_matrix/media/v3/upload. Typing indicators. Room discovery ueber joined_rooms.", "matrix");
    kg_seed_knowledge("Wissensgraph-Architektur", "Multi-Soul-System mit fuenf Domains nach Prioritaet: 1. souls (Multi-Soul Graph: pro Seele identity/tone/traits/empathy/user_model, per-Room Binding, eigener Matrix-Account), 2. kg_tools (Tool-Registry, Vektor-Suche), 3. kg_own (Selbstwissen: Varg-Sprache, Architektur, eigener Code, Vektor-Suche), 4. per-Room conv/vec/graph (permanentes Gespraechsgedaechtnis  - nie vergessen). Neue Tools automatisch in kg_tools registriert. Neue Seelen per !soul create.", "knowledge");

    // ===== Store agent source code reference =====
    var own_code = load_file("/app/agent.varg");
    if own_code != "" {
        var vh = vector_store_open("kg_own");
        var code_emb = embed("Varg Agent Quellcode Architektur Funktionen");
        var code_meta = {"title": "agent.varg", "content": "Kompletter Agent-Quellcode unter /app/agent.varg", "category": "source"};
        vector_store_upsert(vh, "agent_source", code_emb, code_meta);
    }

    store_file("/app/data/kg_version.txt", current_version);
    log_info("Knowledge graph seeded: Multi-Soul + Tools + Self-Knowledge (souls, kg_tools, kg_own, per-room)");
}

// ===== Matrix HTTP =====

fn do_login_http(Config cfg) -> string {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var uname = cfg.username;
    var pass = cfg.password;
    var hs = cfg.homeserver;
    var p1 = jpair(Q, "type", "m.login.password");
    var id_key = jq(Q, "identifier");
    var p2 = jpair(Q, "type", "m.id.user");
    var p3 = jpair(Q, "user", uname);
    var p4 = jpair(Q, "password", pass);
    var p5 = jpair(Q, "initial_device_display_name", "Rose v11");
    var body = $"{L}{p1}, {id_key}: {L}{p2}, {p3}{R}, {p4}, {p5}{R}";
    var headers = {"Content-Type": "application/json"};
    var url = $"{hs}/_matrix/client/v3/login";
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

// String-only login (avoids consuming Config struct)
fn do_login_str(string hs, string username, string password) -> string {
    var Q = env("JSON_Q");
    var L = "{";
    var R = "}";
    var p1 = jpair(Q, "type", "m.login.password");
    var id_key = jq(Q, "identifier");
    var p2 = jpair(Q, "type", "m.id.user");
    var p3 = jpair(Q, "user", username);
    var p4 = jpair(Q, "password", password);
    var p5 = jpair(Q, "initial_device_display_name", "Rose v11");
    var body = $"{L}{p1}, {id_key}: {L}{p2}, {p3}{R}, {p4}, {p5}{R}";
    var headers = {"Content-Type": "application/json"};
    var url = $"{hs}/_matrix/client/v3/login";
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

// Auto-register account on Conduit (uses m.login.dummy auth)
fn do_register_http(string hs, string username, string password, string display_name) -> string {
    var Q = env("JSON_Q");
    var L = "{";
    var R = "}";
    var auth_key = jq(Q, "auth");
    var auth_type = jpair(Q, "type", "m.login.dummy");
    var p1 = jpair(Q, "username", username);
    var p2 = jpair(Q, "password", password);
    var p3 = jpair(Q, "initial_device_display_name", display_name);
    var body = $"{L}{auth_key}: {L}{auth_type}{R}, {p1}, {p2}, {p3}{R}";
    var headers = {"Content-Type": "application/json"};
    var url = $"{hs}/_matrix/client/v3/register";
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, body) or "";
    }
    return resp;
}

fn do_sync_http(Config cfg, Session sess, string wait_str) -> string {
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var nb = sess.next_batch;
    var url = $"{hs}/_matrix/client/v3/sync?access_token={at}&timeout={wait_str}";
    if nb != "" {
        url = $"{url}&since={nb}";
    }
    var headers = {"Content-Type": "application/json"};
    var resp = "";
    unsafe {
        resp = http_request(url, "GET", headers, "") or "";
    }
    return resp;
}

// fetch_joined_rooms_http removed - inlined into discover_rooms_str

fn send_msg_to(Config cfg, Session sess, string room_id, string text) {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var nl = cfg.NL;
    var cr = cfg.CR;
    var tab = cfg.TAB;
    var p1 = jpair(Q, "msgtype", "m.text");
    var safe_text = json_escape_with(text, nl, cr, tab);
    var p2 = jpair(Q, "body", safe_text);
    var body = $"{L}{p1}, {p2}{R}";
    var ts = time_millis();
    var path = $"{hs}/_matrix/client/v3/rooms/{room_id}/send/m.room.message/varg_{ts}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "PUT", headers, body);
    }
}

fn set_typing_in(Config cfg, Session sess, string room_id, bool on) {
    var Q = cfg.Q;
    var L = cfg.L;
    var R = cfg.R;
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var uid = sess.user_id;
    var t = "false";
    if on {
        t = "true";
    }
    var p1 = jpair_raw(Q, "typing", t);
    var p2 = jpair_raw(Q, "timeout", "30000");
    var body = $"{L}{p1}, {p2}{R}";
    var path = $"{hs}/_matrix/client/v3/rooms/{room_id}/typing/{uid}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "PUT", headers, body);
    }
}

fn do_join(Config cfg, Session sess, string room_id) {
    if room_id == "" {
        return;
    }
    var hs = cfg.homeserver;
    var at = sess.access_token;
    var path = $"{hs}/_matrix/client/v3/join/{room_id}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "POST", headers, "{}");
    }
    log_info($"Joined room: {room_id}");
}

// String-only version to avoid cfg/sess ownership issues
fn do_join_str(string hs, string at, string room_id) {
    if room_id == "" {
        return;
    }
    var path = $"{hs}/_matrix/client/v3/join/{room_id}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "POST", headers, "{}");
    }
    log_info($"Joined room: {room_id}");
}

// ===== File Upload & Send (string-only, no cfg/sess) =====

fn upload_to_matrix(string hs, string at, string filename, string content) {
    var url = $"{hs}/_matrix/media/v3/upload?access_token={at}&filename={filename}";
    var headers = {"Content-Type": "text/plain"};
    var resp = "";
    unsafe {
        resp = http_request(url, "POST", headers, content) or "";
    }
    if resp == "" {
        store_file("/app/data/upload_uri.txt", "");
        return;
    }
    var wrap = json_parse(resp)?;
    var body_str = json_get(wrap, "/body");
    var parsed = json_parse(body_str)?;
    var uri = json_get(parsed, "/content_uri");
    store_file("/app/data/upload_uri.txt", uri);
}

fn send_file_to_room(string hs, string at, string room_id, string filename, string mxc_uri) {
    var Q = env("JSON_Q");
    var L = "{";
    var R = "}";
    var p1 = jpair(Q, "msgtype", "m.file");
    var p2 = jpair(Q, "body", filename);
    var p3 = jpair(Q, "url", mxc_uri);
    var info_key = jq(Q, "info");
    var mime = jpair(Q, "mimetype", "text/plain");
    var body = $"{L}{p1}, {p2}, {p3}, {info_key}: {L}{mime}{R}{R}";
    var ts = time_millis();
    var path = $"{hs}/_matrix/client/v3/rooms/{room_id}/send/m.room.message/varg_file_{ts}?access_token={at}";
    var headers = {"Content-Type": "application/json"};
    unsafe {
        http_request(path, "PUT", headers, body);
    }
}

