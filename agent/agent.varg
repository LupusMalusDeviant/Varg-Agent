fn discover_tools(string user_msg) {
    var vh = vector_store_open("kg_tools");
    var emb = embed(user_msg);
    var results = vector_store_search(vh, emb, 8);
    var nl = env("JSON_NL");
    var ctx = "";
    var count = results.len();
    if count > 0 {
        var n0 = results[0]["name"];
        var d0 = results[0]["description"];
        var a0 = results[0]["arguments"];
        ctx = $"{n0}({a0}) - {d0}";
    }
    if count > 1 {
        var n1 = results[1]["name"];
        var d1 = results[1]["description"];
        var a1 = results[1]["arguments"];
        var line1 = $"{n1}({a1}) - {d1}";
        ctx = $"{ctx}{nl}{line1}";
    }
    if count > 2 {
        var n2 = results[2]["name"];
        var d2 = results[2]["description"];
        var a2 = results[2]["arguments"];
        var line2 = $"{n2}({a2}) - {d2}";
        ctx = $"{ctx}{nl}{line2}";
    }
    if count > 3 {
        var n3 = results[3]["name"];
        var d3 = results[3]["description"];
        var a3 = results[3]["arguments"];
        var line3 = $"{n3}({a3}) - {d3}";
        ctx = $"{ctx}{nl}{line3}";
    }
    if count > 4 {
        var n4 = results[4]["name"];
        var d4 = results[4]["description"];
        var a4 = results[4]["arguments"];
        var line4 = $"{n4}({a4}) - {d4}";
        ctx = $"{ctx}{nl}{line4}";
    }
    if count > 5 {
        var n5 = results[5]["name"];
        var d5 = results[5]["description"];
        var a5 = results[5]["arguments"];
        var line5 = $"{n5}({a5}) - {d5}";
        ctx = $"{ctx}{nl}{line5}";
    }
    if count > 6 {
        var n6 = results[6]["name"];
        var d6 = results[6]["description"];
        var a6 = results[6]["arguments"];
        var line6 = $"{n6}({a6}) - {d6}";
        ctx = $"{ctx}{nl}{line6}";
    }
    if count > 7 {
        var n7 = results[7]["name"];
        var d7 = results[7]["description"];
        var a7 = results[7]["arguments"];
        var line7 = $"{n7}({a7}) - {d7}";
        ctx = $"{ctx}{nl}{line7}";
    }
    store_file("/app/data/kg_tools.txt", ctx);
}

fn discover_own_knowledge(string user_msg) {
    var vh = vector_store_open("kg_own");
    var emb = embed(user_msg);
    var results = vector_store_search(vh, emb, 3);
    var nl = env("JSON_NL");
    var ctx = "";
    var count = results.len();
    if count > 0 {
        var t0 = results[0]["title"];
        var c0 = results[0]["content"];
        ctx = $"{t0}: {c0}";
    }
    if count > 1 {
        var t1 = results[1]["title"];
        var c1 = results[1]["content"];
        var line1 = $"{t1}: {c1}";
        ctx = $"{ctx}{nl}{line1}";
    }
    if count > 2 {
        var t2 = results[2]["title"];
        var c2 = results[2]["content"];
        var line2 = $"{t2}: {c2}";
        ctx = $"{ctx}{nl}{line2}";
    }
    store_file("/app/data/kg_own.txt", ctx);
}

// Build complete RAG context from all sources (room-specific + knowledge graph)
fn build_rag_context(string room_id, string user_msg) -> string {
    var rid1 = $"{room_id}";
    var rid2 = $"{room_id}";
    var msg1 = $"{user_msg}";
    var msg2 = $"{user_msg}";
    var msg3 = $"{user_msg}";
    var msg4 = $"{user_msg}";

    // 1. Soul (always fully loaded - highest priority, per-room binding)
    var rid_soul = $"{room_id}";
    load_soul_context(rid_soul);
    // 2. Tool discovery (all tools for capability questions, top-8 otherwise)
    var msg_cap = $"{user_msg}";
    var is_cap = is_capability_question(msg_cap);
    if is_cap {
        load_all_tools();
    }
    if !is_cap {
        discover_tools(msg3);
    }
    // 3. Self-knowledge discovery (Varg language + architecture)
    discover_own_knowledge(msg4);
    // 4. Room-specific RAG (episodic memory + vector similarity)
    recall_memory_context(rid1, msg1);
    search_vector_context(rid2, msg2);

    // Collect all results - priority order: Soul > Tools > Self > Memory > Vectors
    var soul_ctx = load_file("/app/data/kg_soul.txt");
    var tools_ctx = load_file("/app/data/kg_tools.txt");
    var own_ctx = load_file("/app/data/kg_own.txt");
    var mem_ctx = load_file("/app/data/rag_memory.txt");
    var vec_ctx = load_file("/app/data/rag_vector.txt");
    var nl = env("JSON_NL");
    var rag = "";

    // Soul always first
    if soul_ctx != "" {
        rag = $"[Soul]{nl}{soul_ctx}";
    }
    if tools_ctx != "" {
        if rag != "" { rag = $"{rag}{nl}{nl}[Verfuegbare Tools]{nl}{tools_ctx}"; }
        else { rag = $"[Verfuegbare Tools]{nl}{tools_ctx}"; }
    }
    if own_ctx != "" {
        if rag != "" { rag = $"{rag}{nl}{nl}[Relevantes Wissen]{nl}{own_ctx}"; }
        else { rag = $"[Relevantes Wissen]{nl}{own_ctx}"; }
    }
    if mem_ctx != "" {
        if rag != "" { rag = $"{rag}{nl}{nl}[Relevante Erinnerungen]{nl}{mem_ctx}"; }
        else { rag = $"[Relevante Erinnerungen]{nl}{mem_ctx}"; }
    }
    if vec_ctx != "" {
        if rag != "" { rag = $"{rag}{nl}{nl}[Aehnliche Nachrichten]{nl}{vec_ctx}"; }
        else { rag = $"[Aehnliche Nachrichten]{nl}{vec_ctx}"; }
    }
    return rag;
}

// ===== Prompt Building =====

fn build_llm_input(string history, string user_msg, string nl, string rag_context) -> string {
    var input_text = "";
    if rag_context != "" {
        if history != "" {
            input_text = $"Relevanter Kontext aus frueheren Gespraechen:{nl}{rag_context}{nl}{nl}Bisheriges Gespraech:{nl}{history}{nl}Aktuelle Nachricht: {user_msg}";
        } else {
            input_text = $"Relevanter Kontext:{nl}{rag_context}{nl}{nl}Aktuelle Nachricht: {user_msg}";
        }
    } else {
        if history != "" {
            input_text = $"Bisheriges Gespraech:{nl}{history}{nl}Aktuelle Nachricht: {user_msg}";
        } else {
            input_text = user_msg;
        }
    }
    return input_text;
}

// ===== Tool System =====

fn has_tool_call(string text) -> bool {
    if text.contains("<tool_call>") { return true; }
    // Fallback: detect markdown code block format with tool_call
    if text.contains("tool_call") {
        if text.contains("arguments") { return true; }
    }
    return false;
}

fn extract_tool_json(string text) -> string {
    var fb_text = $"{text}";
    // Try XML tags first
    if text.contains("<tool_call>") {
        var start_pos = text.index_of("<tool_call>");
        var after_tag = start_pos + 11;
        var remaining = text.substring(after_tag, 5000);
        if remaining.contains("</tool_call>") {
            var end_pos = remaining.index_of("</tool_call>");
            return remaining.substring(0, end_pos);
        }
    }
    // Fallback: find raw JSON with "arguments" pattern (handles markdown code blocks)
    if fb_text.contains("arguments") {
        var search = $"{fb_text}";
        if fb_text.contains("tool_call") {
            var tc_pos = fb_text.index_of("tool_call");
            var after_tc = tc_pos + 9;
            search = fb_text.substring(after_tc, 5000);
        }
        if search.contains("{") {
            var brace_pos = search.index_of("{");
            var after_brace = search.substring(brace_pos, 5000);
            // Find closing }} (nested JSON with arguments object)
            if after_brace.contains("}}") {
                var end = after_brace.index_of("}}");
                var json_len = end + 2;
                return after_brace.substring(0, json_len);
            }
        }
    }
    return "";
}

fn extract_text_before_tool(string text) -> string {
    if text.contains("<tool_call>") {
        var pos = text.index_of("<tool_call>");
        if pos == 0 { return ""; }
        return text.substring(0, pos);
    }
    if text.contains("tool_call") {
        var pos = text.index_of("tool_call");
        // Back up to find start of code block (```)
        if pos > 3 {
            var before = text.substring(0, pos);
            if before.contains("`") {
                var bp = before.index_of("`");
                if bp == 0 { return ""; }
                return text.substring(0, bp);
            }
        }
        if pos == 0 { return ""; }
        return text.substring(0, pos);
    }
    return text;
}

// Native PDF generation (no LLM call) + upload via sidecar
// Void function so json_parse()? works (Varg bug #3: Ok(()) only valid in void fns)
fn do_generate_pdf(string room_id, string raw_json) {
    log_info($"[PDF] raw_json: {raw_json}");
    var pj = json_parse(raw_json)?;
    var pdf_title = json_get(pj, "/arguments/title");
    if pdf_title == "" { pdf_title = json_get(pj, "/title"); }
    if pdf_title == "" { pdf_title = "Dokument"; }
    var pdf_fname = json_get(pj, "/arguments/filename");
    if pdf_fname == "" { pdf_fname = json_get(pj, "/filename"); }
    if pdf_fname == "" { pdf_fname = "document.pdf"; }
    var fname_c = $"{pdf_fname}";
    var doc = pdf_create(pdf_title);
    // Iterate sections directly via JSON pointer into the parsed tool JSON
    // json_get cannot extract arrays as strings, so we access elements by index
    var sec_idx = 0;
    var sec_done = false;
    var has_sections = false;
    while !sec_done {
        // Try /arguments/sections/N/body first
        var sec_path = $"/arguments/sections/{sec_idx}/body";
        var sec_body = json_get(pj, sec_path);
        if sec_body == "" {
            sec_path = $"/arguments/sections/{sec_idx}/content";
            sec_body = json_get(pj, sec_path);
        }
        if sec_body == "" {
            sec_path = $"/arguments/sections/{sec_idx}/text";
            sec_body = json_get(pj, sec_path);
        }
        // Also try without /arguments/ wrapper
        if sec_body == "" {
            sec_path = $"/sections/{sec_idx}/body";
            sec_body = json_get(pj, sec_path);
        }
        if sec_body == "" {
            sec_path = $"/sections/{sec_idx}/content";
            sec_body = json_get(pj, sec_path);
        }
        log_info($"[PDF] sec[{sec_idx}] body: '{sec_body}'");
        if sec_body == "" { sec_done = true; }
        if sec_body != "" {
            has_sections = true;
            var head_path = $"/arguments/sections/{sec_idx}/heading";
            var sec_heading = json_get(pj, head_path);
            if sec_heading == "" {
                head_path = $"/arguments/sections/{sec_idx}/title";
                sec_heading = json_get(pj, head_path);
            }
            if sec_heading == "" {
                head_path = $"/sections/{sec_idx}/heading";
                sec_heading = json_get(pj, head_path);
            }
            if sec_heading != "" { pdf_add_section(doc, sec_heading, sec_body); }
            if sec_heading == "" { pdf_add_text(doc, sec_body); }
            sec_idx = sec_idx + 1;
        }
    }
    if !has_sections {
        // Fallback: try body/content/text as flat arguments
        var body_text = json_get(pj, "/arguments/body");
        if body_text == "" { body_text = json_get(pj, "/arguments/content"); }
        if body_text == "" { body_text = json_get(pj, "/arguments/text"); }
        if body_text == "" { body_text = json_get(pj, "/body"); }
        if body_text == "" { body_text = json_get(pj, "/content"); }
        if body_text == "" { body_text = json_get(pj, "/text"); }
        if body_text == "" { body_text = "Kein Inhalt angegeben."; }
        pdf_add_text(doc, body_text);
    }
    var b64 = pdf_to_base64(doc);
    if b64 == "" {
        store_file("/app/data/pdf_result.txt", "PDF generation failed");
        return;
    }
    var at = load_file("/app/data/matrix_at.txt");
    var Q = env("JSON_Q");
    var L = "{";
    var R = "}";
    var p1 = jpair(Q, "data_base64", b64);
    var p2 = jpair(Q, "filename", pdf_fname);
    var p3 = jpair(Q, "access_token", at);
    var p4 = jpair(Q, "content_type", "application/pdf");
    var upload_body = $"{L}{p1}, {p2}, {p3}, {p4}{R}";
    var upload_headers = {"Content-Type": "application/json"};
    var upload_resp = "";
    unsafe {
        upload_resp = http_request("http://stt:5000/upload-base64", "POST", upload_headers, upload_body) or "";
    }
    if upload_resp == "" {
        store_file("/app/data/pdf_result.txt", "Upload sidecar not reachable");
        return;
    }
    var uw = json_parse(upload_resp)?;
    var ub = json_get(uw, "/body");
    if ub == "" {
        store_file("/app/data/pdf_result.txt", "Upload response parse error");
        return;
    }
    var up = json_parse(ub)?;
    var up_err = json_get(up, "/error");
    if up_err != "" {
        store_file("/app/data/pdf_result.txt", $"PDF upload failed: {up_err}");
        return;
    }
    var mxc_uri = json_get(up, "/mxc_uri");
    if mxc_uri == "" {
        store_file("/app/data/pdf_result.txt", "PDF upload returned no URI");
        return;
    }
    var hs2 = load_file("/app/data/matrix_hs.txt");
    var at2 = load_file("/app/data/matrix_at.txt");
    var rid = $"{room_id}";
    var mxc_copy = $"{mxc_uri}";
    send_pdf_to_room(hs2, at2, rid, fname_c, mxc_copy);
    store_file("/app/data/pdf_result.txt", $"PDF '{pdf_fname}' erstellt und im Chat gesendet");
}

fn execute_tool(string room_id, string tool_json) {
    var parsed = json_parse(tool_json)?;
    var name = json_get(parsed, "/name");
    store_file("/app/data/tool_name.txt", name);
    var result = "";
    if name == "read_file" {
        var fpath = json_get(parsed, "/arguments/path");
        if !fpath.starts_with("/") {
            fpath = $"/app/data/{fpath}";
        }
        result = load_file(fpath);
        if result == "" { result = "File not found or empty"; }
    }
    if name == "write_file" {
        var fpath = json_get(parsed, "/arguments/path");
        if !fpath.starts_with("/") {
            fpath = $"/app/data/{fpath}";
        }
        var fpath_copy = $"{fpath}";
        var fpath_c2 = $"{fpath}";
        var content = json_get(parsed, "/arguments/content");
        var content_copy = $"{content}";
        store_file(fpath, content);
        // Always auto-send written files to chat
        var hs = load_file("/app/data/matrix_hs.txt");
        var at = load_file("/app/data/matrix_at.txt");
        upload_to_matrix(hs, at, fpath_copy, content_copy);
        var uri = load_file("/app/data/upload_uri.txt");
        if uri != "" {
            var hs2 = load_file("/app/data/matrix_hs.txt");
            var at2 = load_file("/app/data/matrix_at.txt");
            var rid = $"{room_id}";
            var uri_copy = $"{uri}";
            send_file_to_room(hs2, at2, rid, fpath_c2, uri_copy);
            result = $"File created and sent to chat";
        }
        if uri == "" {
            result = $"File written but could not send to chat";
        }
    }
    if name == "remember" {
        var text = json_get(parsed, "/arguments/text");
        var rid1 = $"{room_id}";
        var existing = kb_recall_room(rid1, "notes");
        var nl = env("JSON_NL");
        var updated = $"{existing}{nl}{text}";
        var rid2 = $"{room_id}";
        kb_store_room(rid2, "notes", updated);
        result = $"Stored: {text}";
    }
    if name == "recall" {
        var rid3 = $"{room_id}";
        var notes = kb_recall_room(rid3, "notes");
        if notes == "" { result = "No stored notes in this room."; }
        else { result = notes; }
    }
    if name == "get_time" {
        var ts = time_millis();
        result = $"{ts}";
    }
    if name == "send_file" {
        var fpath = json_get(parsed, "/arguments/path");
        if !fpath.starts_with("/") {
            fpath = $"/app/data/{fpath}";
        }
        var fc1 = $"{fpath}";
        var fc2 = $"{fpath}";
        var fc3 = $"{fpath}";
        var fc4 = $"{fpath}";
        var content = load_file(fpath);
        if content == "" {
            result = $"File not found or empty: {fc1}";
        }
        if content != "" {
            var hs = load_file("/app/data/matrix_hs.txt");
            var at = load_file("/app/data/matrix_at.txt");
            upload_to_matrix(hs, at, fc1, content);
            var uri = load_file("/app/data/upload_uri.txt");
            var uri_copy = $"{uri}";
            if uri != "" {
                var hs2 = load_file("/app/data/matrix_hs.txt");
                var at2 = load_file("/app/data/matrix_at.txt");
                var rid = $"{room_id}";
                send_file_to_room(hs2, at2, rid, fc2, uri_copy);
                result = $"File sent to chat: {fc3}";
            }
            if uri == "" {
                result = $"Upload failed for: {fc4}";
            }
        }
    }
    if name == "run_code" {
        var image = json_get(parsed, "/arguments/image");
        var cmd = json_get(parsed, "/arguments/command");
        var repo_arg = json_get(parsed, "/arguments/repo_id");
        if image == "" { image = "python:3.11-slim"; }
        var sb_url = env("SANDBOX_URL");
        if sb_url == "" { sb_url = "http://sandbox:5001"; }
        var Q = env("JSON_Q");
        var L = "{";
        var R = "}";
        var p1 = jpair(Q, "image", image);
        var p2 = jpair(Q, "command", cmd);
        var p3 = jpair_raw(Q, "timeout", "30");
        var sb_body = "";
        if repo_arg != "" {
            var p4 = jpair(Q, "repo_id", repo_arg);
            sb_body = $"{L}{p1}, {p2}, {p3}, {p4}{R}";
        } else {
            sb_body = $"{L}{p1}, {p2}, {p3}{R}";
        }
        var sb_headers = {"Content-Type": "application/json"};
        var sb_resp = "";
        var sb_ep = $"{sb_url}/run";
        unsafe {
            sb_resp = http_request(sb_ep, "POST", sb_headers, sb_body) or "";
        }
        if sb_resp == "" {
            result = "Sandbox not reachable";
        }
        if sb_resp != "" {
            var sb_wrap = json_parse(sb_resp)?;
            var sb_body_str = json_get(sb_wrap, "/body");
            if sb_body_str != "" {
                var sb_parsed = json_parse(sb_body_str)?;
                var stdout = json_get(sb_parsed, "/stdout");
                var stderr = json_get(sb_parsed, "/stderr");
                var exit_code = json_get(sb_parsed, "/exit_code");
                result = $"Exit: {exit_code}";
                if stdout != "" { result = $"{result}\nStdout: {stdout}"; }
                if stderr != "" { result = $"{result}\nStderr: {stderr}"; }
            }
            if sb_body_str == "" {
                result = $"Sandbox response parse error";
            }
        }
    }
    if name == "git_clone" {
        var clone_url = json_get(parsed, "/arguments/url");
        var sb_url = env("SANDBOX_URL");
        if sb_url == "" { sb_url = "http://sandbox:5001"; }
        var Q = env("JSON_Q");
        var L = "{";
        var R = "}";
        var p1 = jpair(Q, "url", clone_url);
        var p2 = jpair_raw(Q, "depth", "1");
        var sb_body = $"{L}{p1}, {p2}{R}";
        var sb_headers = {"Content-Type": "application/json"};
        var sb_resp = "";
        var sb_ep = $"{sb_url}/clone";
        unsafe {
            sb_resp = http_request(sb_ep, "POST", sb_headers, sb_body) or "";
        }
        if sb_resp == "" {
            result = "Sandbox not reachable";
        }
        if sb_resp != "" {
            var sb_wrap = json_parse(sb_resp)?;
            var sb_body_str = json_get(sb_wrap, "/body");
            if sb_body_str != "" {
                var sb_parsed = json_parse(sb_body_str)?;
                var repo_id = json_get(sb_parsed, "/repo_id");
                var file_count = json_get(sb_parsed, "/file_count");
                result = $"Cloned! repo_id={repo_id}, files={file_count}. Use read_repo_file(repo_id, path) to read files or run_code(image, command, repo_id) to execute in the repo.";
            }
            if sb_body_str == "" {
                result = "Clone response parse error";
            }
        }
    }
    if name == "read_repo_file" {
        var repo_id = json_get(parsed, "/arguments/repo_id");
        var fpath = json_get(parsed, "/arguments/path");
        var sb_url = env("SANDBOX_URL");
        if sb_url == "" { sb_url = "http://sandbox:5001"; }
        var Q = env("JSON_Q");
        var L = "{";
        var R = "}";
        var p1 = jpair(Q, "repo_id", repo_id);
        var p2 = jpair(Q, "path", fpath);
        var sb_body = $"{L}{p1}, {p2}{R}";
        var sb_headers = {"Content-Type": "application/json"};
        var sb_resp = "";
        var sb_ep = $"{sb_url}/read";
        unsafe {
            sb_resp = http_request(sb_ep, "POST", sb_headers, sb_body) or "";
        }
        if sb_resp == "" {
            result = "Sandbox not reachable";
        }
        if sb_resp != "" {
            var sb_wrap = json_parse(sb_resp)?;
            var sb_body_str = json_get(sb_wrap, "/body");
            if sb_body_str != "" {
                var sb_parsed = json_parse(sb_body_str)?;
                var content = json_get(sb_parsed, "/content");
                var err = json_get(sb_parsed, "/error");
                if err != "" { result = $"Error: {err}"; }
                if err == "" { result = content; }
            }
            if sb_body_str == "" {
                result = "Read response parse error";
            }
        }
    }
    if name == "build_varg_tool" {
        var tool_name = json_get(parsed, "/arguments/name");
        var tool_code = json_get(parsed, "/arguments/code");
        var tool_desc = json_get(parsed, "/arguments/description");
        if tool_desc == "" { tool_desc = $"Custom Varg tool: {tool_name}"; }
        var tool_path = $"/app/tools/{tool_name}.varg";
        var tc_copy = $"{tool_code}";
        var tc_save = $"{tool_code}";
        store_file(tool_path, tc_save);
        var compile_cmd = $"cd /app && vargc build tools/{tool_name}.varg 2>&1";
        var compile_result = "";
        unsafe {
            compile_result = exec(compile_cmd) or "";
        }
        if compile_result.contains("error") {
            result = $"Compilation failed: {compile_result}";
        }
        if !compile_result.contains("error") {
            // Register in knowledge graph for future discovery
            var tn_copy = $"{tool_name}";
            var td_copy = $"{tool_desc}";
            kg_register_custom_tool(tn_copy, td_copy, tc_copy);
            result = $"Tool {tool_name} compiled and registered in knowledge graph. Run with run_varg_tool(name={tool_name})";
        }
    }
    if name == "run_varg_tool" {
        var tool_name = json_get(parsed, "/arguments/name");
        var tool_args = json_get(parsed, "/arguments/args");
        var tool_bin = $"/app/tools/{tool_name}";
        var run_cmd = $"{tool_bin} {tool_args} 2>&1";
        var run_result = "";
        unsafe {
            run_result = exec(run_cmd) or "";
        }
        if run_result == "" { result = "Tool produced no output"; }
        if run_result != "" { result = run_result; }
    }
    if name == "list_tools" {
        var ls_cmd = "ls -1 /app/tools/ 2>/dev/null";
        var ls_result = "";
        unsafe {
            ls_result = exec(ls_cmd) or "";
        }
        if ls_result == "" { ls_result = "No custom tools yet"; }
        result = $"Custom Varg tools: {ls_result}";
    }
    if name == "generate_pdf" {
        store_file("/app/data/pdf_result.txt", "");
        var rid_copy = $"{room_id}";
        var tj_copy = $"{tool_json}";
        do_generate_pdf(rid_copy, tj_copy);
        result = load_file("/app/data/pdf_result.txt");
        if result == "" { result = "PDF generation completed"; }
    }
    if name == "web_search" {
        var search_query = json_get(parsed, "/arguments/query");
        if search_query == "" {
            result = "Missing query parameter";
        }
        if search_query != "" {
            var Q = env("JSON_Q");
            var L = "{";
            var R = "}";
            var p1 = jpair(Q, "query", search_query);
            var search_body = $"{L}{p1}{R}";
            var search_headers = {"Content-Type": "application/json"};
            var search_resp = "";
            unsafe {
                search_resp = http_request("http://stt:5000/web-search", "POST", search_headers, search_body) or "";
            }
            if search_resp == "" {
                result = "Web search sidecar not reachable";
            }
            if search_resp != "" {
                var sw = json_parse(search_resp)?;
                var search_body = json_get(sw, "/body");
                var sb_check = $"{search_body}";
                if search_body != "" {
                    result = search_body;
                }
                if sb_check == "" {
                    result = "Search returned empty response";
                }
            }
        }
    }
    if name == "fetch_url" {
        var fetch_target = json_get(parsed, "/arguments/url");
        if fetch_target == "" {
            result = "Missing url parameter";
        }
        if fetch_target != "" {
            var Q = env("JSON_Q");
            var L = "{";
            var R = "}";
            var p1 = jpair(Q, "url", fetch_target);
            var fetch_body = $"{L}{p1}{R}";
            var fetch_headers = {"Content-Type": "application/json"};
            var fetch_resp = "";
            unsafe {
                fetch_resp = http_request("http://stt:5000/fetch-url", "POST", fetch_headers, fetch_body) or "";
            }
            if fetch_resp == "" {
                result = "Fetch sidecar not reachable";
            }
            if fetch_resp != "" {
                var fw = json_parse(fetch_resp)?;
                var fb = json_get(fw, "/body");
                if fb != "" {
                    var fp2 = json_parse(fb)?;
                    var ftitle = json_get(fp2, "/title");
                    var ftext = json_get(fp2, "/text");
                    var ferr = json_get(fp2, "/error");
                    if ferr != "" {
                        result = $"Fetch error: {ferr}";
                    }
                    if ferr == "" {
                        result = $"Title: {ftitle}\n\n{ftext}";
                    }
                }
                if fb == "" {
                    result = "Fetch returned empty response";
                }
            }
        }
    }
    if name == "analyze_image" {
        var img_mxc = json_get(parsed, "/arguments/mxc_url");
        var img_prompt = json_get(parsed, "/arguments/prompt");
        if img_prompt == "" { img_prompt = "Beschreibe dieses Bild detailliert auf Deutsch. Was siehst du?"; }
        if img_mxc == "" {
            result = "Missing mxc_url parameter";
        }
        if img_mxc != "" {
            var at = load_file("/app/data/matrix_at.txt");
            var Q = env("JSON_Q");
            var L = "{";
            var R = "}";
            var p1 = jpair(Q, "mxc_url", img_mxc);
            var p2 = jpair(Q, "access_token", at);
            var p3 = jpair(Q, "prompt", img_prompt);
            var img_body = $"{L}{p1}, {p2}, {p3}{R}";
            var img_headers = {"Content-Type": "application/json"};
            var img_resp = "";
            unsafe {
                img_resp = http_request("http://stt:5000/analyze-image", "POST", img_headers, img_body) or "";
            }
            if img_resp == "" {
                result = "Image analysis sidecar not reachable";
            }
            if img_resp != "" {
                var iw = json_parse(img_resp)?;
                var ib = json_get(iw, "/body");
                if ib != "" {
                    var ip = json_parse(ib)?;
                    var idesc = json_get(ip, "/description");
                    var ierr = json_get(ip, "/error");
                    if ierr != "" {
                        result = $"Image analysis error: {ierr}";
                    }
                    if ierr == "" {
                        result = idesc;
                    }
                }
                if ib == "" {
                    result = "Image analysis returned empty response";
                }
            }
        }
    }
    if name == "tts_respond" {
        var tts_text = json_get(parsed, "/arguments/text");
        if tts_text == "" {
            result = "Missing text parameter";
        }
        if tts_text != "" {
            var tts_fname = json_get(parsed, "/arguments/filename");
            if tts_fname == "" { tts_fname = "response.wav"; }
            var tts_fname_c = $"{tts_fname}";
            var tts_fname_c2 = $"{tts_fname}";
            var at = load_file("/app/data/matrix_at.txt");
            var Q = env("JSON_Q");
            var L = "{";
            var R = "}";
            var p1 = jpair(Q, "text", tts_text);
            var p2 = jpair(Q, "access_token", at);
            var p3 = jpair(Q, "filename", tts_fname);
            var tts_body = $"{L}{p1}, {p2}, {p3}{R}";
            var media_url = "http://stt:5000/tts";
            var tts_headers = {"Content-Type": "application/json"};
            var tts_resp = "";
            unsafe {
                tts_resp = http_request(media_url, "POST", tts_headers, tts_body) or "";
            }
            if tts_resp == "" {
                result = "Media sidecar not reachable";
            }
            if tts_resp != "" {
                var tts_wrap = json_parse(tts_resp)?;
                var tts_body_str = json_get(tts_wrap, "/body");
                if tts_body_str != "" {
                    var tts_parsed = json_parse(tts_body_str)?;
                    var mxc_uri = json_get(tts_parsed, "/mxc_uri");
                    var tts_err = json_get(tts_parsed, "/error");
                    if tts_err != "" {
                        result = $"TTS failed: {tts_err}";
                    }
                    if mxc_uri != "" {
                        var hs2 = load_file("/app/data/matrix_hs.txt");
                        var at2 = load_file("/app/data/matrix_at.txt");
                        var rid = $"{room_id}";
                        var mxc_copy = $"{mxc_uri}";
                        send_voice_to_room(hs2, at2, rid, tts_fname_c, mxc_copy);
                        result = $"Voice message '{tts_fname_c2}' sent";
                    }
                    if mxc_uri == "" {
                        if tts_err == "" { result = "TTS upload returned no URI"; }
                    }
                }
                if tts_body_str == "" {
                    result = "TTS response parse error";
                }
            }
        }
    }
    if name == "generate_image" {
        var img_prompt = json_get(parsed, "/arguments/prompt");
        if img_prompt == "" {
            result = "Missing prompt parameter";
        }
        if img_prompt != "" {
            var img_fname = json_get(parsed, "/arguments/filename");
            if img_fname == "" { img_fname = "generated.png"; }
            var img_fname_c = $"{img_fname}";
            var img_fname_c2 = $"{img_fname}";
            var at = load_file("/app/data/matrix_at.txt");
            var Q = env("JSON_Q");
            var L = "{";
            var R = "}";
            var p1 = jpair(Q, "prompt", img_prompt);
            var p2 = jpair(Q, "access_token", at);
            var p3 = jpair(Q, "filename", img_fname);
            var img_body = $"{L}{p1}, {p2}, {p3}{R}";
            var media_url = "http://stt:5000/generate-image";
            var img_headers = {"Content-Type": "application/json"};
            var img_resp = "";
            unsafe {
                img_resp = http_request(media_url, "POST", img_headers, img_body) or "";
            }
            if img_resp == "" {
                result = "Media sidecar not reachable";
            }
            if img_resp != "" {
                var img_wrap = json_parse(img_resp)?;
                var img_body_str = json_get(img_wrap, "/body");
                if img_body_str != "" {
                    var img_parsed = json_parse(img_body_str)?;
                    var mxc_uri = json_get(img_parsed, "/mxc_uri");
                    var img_err = json_get(img_parsed, "/error");
                    if img_err != "" {
                        result = $"Image generation failed: {img_err}";
                    }
                    if mxc_uri != "" {
                        var hs2 = load_file("/app/data/matrix_hs.txt");
                        var at2 = load_file("/app/data/matrix_at.txt");
                        var rid = $"{room_id}";
                        var mxc_copy = $"{mxc_uri}";
                        send_image_to_room(hs2, at2, rid, img_fname_c, mxc_copy);
                        result = $"Image '{img_fname_c2}' generated and sent to chat";
                    }
                    if mxc_uri == "" {
                        if img_err == "" { result = "Image upload returned no URI"; }
                    }
                }
                if img_body_str == "" {
                    result = "Image response parse error";
                }
            }
        }
    }
    if name == "add_todo" {
        var todo_text = json_get(parsed, "/arguments/text");
        if todo_text == "" {
            result = "Missing text parameter";
        }
        if todo_text != "" {
            // Room-specific todo file
            var tcp = $"/app/data/todo_{room_id}_count.txt";
            var tc = load_file(tcp);
            if tc == "" { tc = "0"; }
            var todo_item_path = $"/app/data/todo_{room_id}_{tc}.txt";
            var todo_text_c = $"{todo_text}";
            store_file(todo_item_path, todo_text_c);
            var todo_done_path = $"/app/data/todo_{room_id}_{tc}_done.txt";
            store_file(todo_done_path, "0");
            // Increment count
            var tcp2 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "0" { store_file(tcp2, "1"); }
            var tcp3 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "1" { store_file(tcp3, "2"); }
            var tcp4 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "2" { store_file(tcp4, "3"); }
            var tcp5 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "3" { store_file(tcp5, "4"); }
            var tcp6 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "4" { store_file(tcp6, "5"); }
            var tcp7 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "5" { store_file(tcp7, "6"); }
            var tcp8 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "6" { store_file(tcp8, "7"); }
            var tcp9 = $"/app/data/todo_{room_id}_count.txt";
            if tc == "7" { store_file(tcp9, "8"); }
            var tcpa = $"/app/data/todo_{room_id}_count.txt";
            if tc == "8" { store_file(tcpa, "9"); }
            var tcpb = $"/app/data/todo_{room_id}_count.txt";
            if tc == "9" { store_file(tcpb, "10"); }
            var tcpc = $"/app/data/todo_{room_id}_count.txt";
            if tc == "10" { store_file(tcpc, "11"); }
            var tcpd = $"/app/data/todo_{room_id}_count.txt";
            if tc == "11" { store_file(tcpd, "12"); }
            var tcpe = $"/app/data/todo_{room_id}_count.txt";
            if tc == "12" { store_file(tcpe, "13"); }
            var tcpf = $"/app/data/todo_{room_id}_count.txt";
            if tc == "13" { store_file(tcpf, "14"); }
            var tcpg = $"/app/data/todo_{room_id}_count.txt";
            if tc == "14" { store_file(tcpg, "15"); }
            var tcph = $"/app/data/todo_{room_id}_count.txt";
            if tc == "15" { store_file(tcph, "16"); }
            var tcpi = $"/app/data/todo_{room_id}_count.txt";
            if tc == "16" { store_file(tcpi, "17"); }
            var tcpj = $"/app/data/todo_{room_id}_count.txt";
            if tc == "17" { store_file(tcpj, "18"); }
            var tcpk = $"/app/data/todo_{room_id}_count.txt";
            if tc == "18" { store_file(tcpk, "19"); }
            var tcpl = $"/app/data/todo_{room_id}_count.txt";
            if tc == "19" { store_file(tcpl, "20"); }
            result = $"Aufgabe hinzugefuegt: {todo_text}";
        }
    }
    if name == "list_todos" {
        var tcp = $"/app/data/todo_{room_id}_count.txt";
        var tc = load_file(tcp);
        if tc == "" {
            result = "Keine Aufgaben vorhanden.";
        }
        if tc != "" {
            var todo_list = "";
            // Unrolled loop to avoid while+string interpolation issues
            var tp0 = $"/app/data/todo_{room_id}_0.txt";
            var tt0 = load_file(tp0);
            if tt0 != "" { var dp0 = $"/app/data/todo_{room_id}_0_done.txt"; var d0 = load_file(dp0); if d0 == "1" { todo_list = $"{todo_list}1. [x] {tt0}\n"; } if d0 != "1" { todo_list = $"{todo_list}1. [ ] {tt0}\n"; } }
            var tp1 = $"/app/data/todo_{room_id}_1.txt";
            var tt1 = load_file(tp1);
            if tt1 != "" { var dp1 = $"/app/data/todo_{room_id}_1_done.txt"; var d1 = load_file(dp1); if d1 == "1" { todo_list = $"{todo_list}2. [x] {tt1}\n"; } if d1 != "1" { todo_list = $"{todo_list}2. [ ] {tt1}\n"; } }
            var tp2 = $"/app/data/todo_{room_id}_2.txt";
            var tt2 = load_file(tp2);
            if tt2 != "" { var dp2 = $"/app/data/todo_{room_id}_2_done.txt"; var d2 = load_file(dp2); if d2 == "1" { todo_list = $"{todo_list}3. [x] {tt2}\n"; } if d2 != "1" { todo_list = $"{todo_list}3. [ ] {tt2}\n"; } }
            var tp3 = $"/app/data/todo_{room_id}_3.txt";
            var tt3 = load_file(tp3);
            if tt3 != "" { var dp3 = $"/app/data/todo_{room_id}_3_done.txt"; var d3 = load_file(dp3); if d3 == "1" { todo_list = $"{todo_list}4. [x] {tt3}\n"; } if d3 != "1" { todo_list = $"{todo_list}4. [ ] {tt3}\n"; } }
            var tp4 = $"/app/data/todo_{room_id}_4.txt";
            var tt4 = load_file(tp4);
            if tt4 != "" { var dp4 = $"/app/data/todo_{room_id}_4_done.txt"; var d4 = load_file(dp4); if d4 == "1" { todo_list = $"{todo_list}5. [x] {tt4}\n"; } if d4 != "1" { todo_list = $"{todo_list}5. [ ] {tt4}\n"; } }
            var tp5 = $"/app/data/todo_{room_id}_5.txt";
            var tt5 = load_file(tp5);
            if tt5 != "" { var dp5 = $"/app/data/todo_{room_id}_5_done.txt"; var d5 = load_file(dp5); if d5 == "1" { todo_list = $"{todo_list}6. [x] {tt5}\n"; } if d5 != "1" { todo_list = $"{todo_list}6. [ ] {tt5}\n"; } }
            var tp6 = $"/app/data/todo_{room_id}_6.txt";
            var tt6 = load_file(tp6);
            if tt6 != "" { var dp6 = $"/app/data/todo_{room_id}_6_done.txt"; var d6 = load_file(dp6); if d6 == "1" { todo_list = $"{todo_list}7. [x] {tt6}\n"; } if d6 != "1" { todo_list = $"{todo_list}7. [ ] {tt6}\n"; } }
            var tp7 = $"/app/data/todo_{room_id}_7.txt";
            var tt7 = load_file(tp7);
            if tt7 != "" { var dp7 = $"/app/data/todo_{room_id}_7_done.txt"; var d7 = load_file(dp7); if d7 == "1" { todo_list = $"{todo_list}8. [x] {tt7}\n"; } if d7 != "1" { todo_list = $"{todo_list}8. [ ] {tt7}\n"; } }
            var tp8 = $"/app/data/todo_{room_id}_8.txt";
            var tt8 = load_file(tp8);
            if tt8 != "" { var dp8 = $"/app/data/todo_{room_id}_8_done.txt"; var d8 = load_file(dp8); if d8 == "1" { todo_list = $"{todo_list}9. [x] {tt8}\n"; } if d8 != "1" { todo_list = $"{todo_list}9. [ ] {tt8}\n"; } }
            var tp9 = $"/app/data/todo_{room_id}_9.txt";
            var tt9 = load_file(tp9);
            if tt9 != "" { var dp9 = $"/app/data/todo_{room_id}_9_done.txt"; var d9 = load_file(dp9); if d9 == "1" { todo_list = $"{todo_list}10. [x] {tt9}\n"; } if d9 != "1" { todo_list = $"{todo_list}10. [ ] {tt9}\n"; } }
            if todo_list == "" {
                result = "Keine Aufgaben vorhanden.";
            }
            if todo_list != "" {
                result = $"Todo-Liste:\n{todo_list}";
            }
        }
    }
    if name == "done_todo" {
        var todo_num = json_get(parsed, "/arguments/number");
        if todo_num == "" {
            result = "Missing number parameter";
        }
        if todo_num != "" {
            // Convert 1-based number to 0-based index string
            var tidx = "0";
            if todo_num == "1" { tidx = "0"; }
            if todo_num == "2" { tidx = "1"; }
            if todo_num == "3" { tidx = "2"; }
            if todo_num == "4" { tidx = "3"; }
            if todo_num == "5" { tidx = "4"; }
            if todo_num == "6" { tidx = "5"; }
            if todo_num == "7" { tidx = "6"; }
            if todo_num == "8" { tidx = "7"; }
            if todo_num == "9" { tidx = "8"; }
            if todo_num == "10" { tidx = "9"; }
            var tp = $"/app/data/todo_{room_id}_{tidx}.txt";
            var ttext = load_file(tp);
            if ttext == "" {
                result = $"Aufgabe {todo_num} nicht gefunden";
            }
            if ttext != "" {
                var dp = $"/app/data/todo_{room_id}_{tidx}_done.txt";
                store_file(dp, "1");
                result = $"Aufgabe {todo_num} erledigt: {ttext}";
            }
        }
    }
    if name == "set_reminder" {
        var rem_minutes = json_get(parsed, "/arguments/minutes");
        var rem_text = json_get(parsed, "/arguments/text");
        if rem_text == "" { rem_text = "Erinnerung!"; }
        if rem_minutes == "" { rem_minutes = "5"; }
        // Convert minutes to sync cycles (~30s each)
        var cycles = "10"; // default 5 min
        if rem_minutes == "1" { cycles = "2"; }
        if rem_minutes == "2" { cycles = "4"; }
        if rem_minutes == "3" { cycles = "6"; }
        if rem_minutes == "5" { cycles = "10"; }
        if rem_minutes == "10" { cycles = "20"; }
        if rem_minutes == "15" { cycles = "30"; }
        if rem_minutes == "20" { cycles = "40"; }
        if rem_minutes == "30" { cycles = "60"; }
        if rem_minutes == "45" { cycles = "90"; }
        if rem_minutes == "60" { cycles = "120"; }
        if rem_minutes == "90" { cycles = "180"; }
        if rem_minutes == "120" { cycles = "240"; }
        var rid_rem = $"{room_id}";
        var rem_idx = load_file("/app/data/reminder_count.txt");
        if rem_idx == "" { rem_idx = "0"; }
        var rem_due_path = $"/app/data/reminder_{rem_idx}_due.txt";
        var rem_room_path = $"/app/data/reminder_{rem_idx}_room.txt";
        var rem_text_path = $"/app/data/reminder_{rem_idx}_text.txt";
        // Store cycle countdown directly (no parsing needed)
        store_file(rem_due_path, cycles);
        store_file(rem_room_path, rid_rem);
        store_file(rem_text_path, rem_text);
        // Increment reminder count
        if rem_idx == "0" { store_file("/app/data/reminder_count.txt", "1"); }
        if rem_idx == "1" { store_file("/app/data/reminder_count.txt", "2"); }
        if rem_idx == "2" { store_file("/app/data/reminder_count.txt", "3"); }
        if rem_idx == "3" { store_file("/app/data/reminder_count.txt", "4"); }
        if rem_idx == "4" { store_file("/app/data/reminder_count.txt", "5"); }
        if rem_idx == "5" { store_file("/app/data/reminder_count.txt", "6"); }
        if rem_idx == "6" { store_file("/app/data/reminder_count.txt", "7"); }
        if rem_idx == "7" { store_file("/app/data/reminder_count.txt", "8"); }
        if rem_idx == "8" { store_file("/app/data/reminder_count.txt", "9"); }
        result = $"Erinnerung gesetzt: '{rem_text}' in {rem_minutes} Minuten";
    }

    // ===== Phase 2: Nice-to-Have Tools =====

    if name == "get_weather" {
        var wloc = json_get(parsed, "/arguments/location");
        var wunits = json_get(parsed, "/arguments/units");
        if wunits == "" { wunits = "metric"; }
        if wloc == "" {
            result = "Missing location parameter";
        }
        if wloc != "" {
            var wkey = get_cfg("OPENWEATHERMAP_API_KEY");
            if wkey == "" {
                result = "OPENWEATHERMAP_API_KEY not configured";
            }
            if wkey != "" {
                var wurl = $"https://api.openweathermap.org/data/2.5/weather?q={wloc}&units={wunits}&appid={wkey}&lang=de";
                var wheaders = {"Content-Type": "application/json"};
                var wresp = "";
                unsafe {
                    wresp = http_request(wurl, "GET", wheaders, "") or "";
                }
                if wresp == "" {
                    result = "Weather API nicht erreichbar";
                }
                if wresp != "" {
                    var ww = json_parse(wresp)?;
                    var wb = json_get(ww, "/body");
                    if wb != "" {
                        var wp = json_parse(wb)?;
                        var wtemp = json_get(wp, "/main/temp");
                        var wfeel = json_get(wp, "/main/feels_like");
                        var whum = json_get(wp, "/main/humidity");
                        var wdesc = json_get(wp, "/weather/0/description");
                        var wwind = json_get(wp, "/wind/speed");
                        var wcity = json_get(wp, "/name");
                        result = $"Wetter in {wcity}: {wdesc}, {wtemp}C (gefuehlt {wfeel}C), Luftfeuchtigkeit {whum}%, Wind {wwind} m/s";
                    }
                    if wb == "" {
                        result = "Weather API returned empty response";
                    }
                }
            }
        }
    }

    if name == "translate" {
        var tr_text = json_get(parsed, "/arguments/text");
        var tr_target = json_get(parsed, "/arguments/target_lang");
        var tr_source = json_get(parsed, "/arguments/source_lang");
        var tr_text_chk = $"{tr_text}";
        if tr_text == "" {
            result = "Missing text parameter";
        }
        if tr_target == "" { tr_target = "Englisch"; }
        if tr_text_chk != "" {
            var gkey = get_cfg("GEMINI_API_KEY");
            var gkey_chk = $"{gkey}";
            if gkey == "" {
                result = "GEMINI_API_KEY not configured";
            }
            if gkey_chk != "" {
                var Q = env("JSON_Q");
                var Q2 = $"{Q}";
                var Q3 = $"{Q}";
                var Q4 = $"{Q}";
                var Q5 = $"{Q}";
                var L = "{";
                var L2 = $"{L}";
                var L3 = $"{L}";
                var R = "}";
                var R2 = $"{R}";
                var R3 = $"{R}";
                var tr_prompt = "";
                var tr_src_chk = $"{tr_source}";
                if tr_source == "" {
                    tr_prompt = $"Translate the following text to {tr_target}. Return ONLY the translation, nothing else: {tr_text}";
                }
                if tr_src_chk != "" {
                    tr_prompt = $"Translate the following text from {tr_source} to {tr_target}. Return ONLY the translation, nothing else: {tr_text}";
                }
                var tr_url = $"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={gkey}";
                var tp1 = jpair(Q, "text", tr_prompt);
                var tr_body = $"{L}{Q2}contents{Q3}:[{L2}{Q4}parts{Q5}:[{L3}{tp1}{R}{R2}]{R3}]";
                var tr_body_final = $"{tr_body}}}";
                var tr_headers = {"Content-Type": "application/json"};
                var tr_resp = "";
                unsafe {
                    tr_resp = http_request(tr_url, "POST", tr_headers, tr_body_final) or "";
                }
                if tr_resp == "" {
                    result = "Translation API nicht erreichbar";
                }
                if tr_resp != "" {
                    var trw = json_parse(tr_resp)?;
                    var trb = json_get(trw, "/body");
                    if trb != "" {
                        var trp = json_parse(trb)?;
                        var tr_result = json_get(trp, "/candidates/0/content/parts/0/text");
                        var tr_result_chk = $"{tr_result}";
                        if tr_result != "" {
                            result = $"{tr_result_chk}";
                        }
                        if tr_result_chk == "" {
                            result = "Translation returned no result";
                        }
                    }
                }
            }
        }
    }

    if name == "smarthome_status" {
        var ha_eid = json_get(parsed, "/arguments/entity_id");
        if ha_eid == "" {
            result = "Missing entity_id parameter";
        }
        if ha_eid != "" {
            var ha_url = get_cfg("HASS_URL");
            var ha_token = get_cfg("HASS_TOKEN");
            if ha_url == "" {
                result = "HASS_URL not configured";
            }
            if ha_url != "" {
                var ha_api = $"{ha_url}/api/states/{ha_eid}";
                var ha_auth = $"Bearer {ha_token}";
                var ha_headers = {"Authorization": ha_auth, "Content-Type": "application/json"};
                var ha_resp = "";
                unsafe {
                    ha_resp = http_request(ha_api, "GET", ha_headers, "") or "";
                }
                if ha_resp == "" {
                    result = "Home Assistant nicht erreichbar";
                }
                if ha_resp != "" {
                    var haw = json_parse(ha_resp)?;
                    var hab = json_get(haw, "/body");
                    if hab != "" {
                        var hap = json_parse(hab)?;
                        var ha_state = json_get(hap, "/state");
                        var ha_fname = json_get(hap, "/attributes/friendly_name");
                        var ha_unit = json_get(hap, "/attributes/unit_of_measurement");
                        result = $"{ha_fname} ({ha_eid}): {ha_state} {ha_unit}";
                    }
                }
            }
        }
    }

    if name == "smarthome_control" {
        var hc_eid = json_get(parsed, "/arguments/entity_id");
        var hc_action = json_get(parsed, "/arguments/action");
        var hc_bright = json_get(parsed, "/arguments/brightness");
        var hc_temp = json_get(parsed, "/arguments/temperature");
        if hc_eid == "" {
            result = "Missing entity_id parameter";
        }
        if hc_action == "" { hc_action = "toggle"; }
        if hc_eid != "" {
            var ha_url = get_cfg("HASS_URL");
            var ha_token = get_cfg("HASS_TOKEN");
            if ha_url == "" {
                result = "HASS_URL not configured";
            }
            if ha_url != "" {
                // Extract domain from entity_id (e.g. "light" from "light.wohnzimmer")
                var hc_domain = "";
                if hc_eid.starts_with("light.") { hc_domain = "light"; }
                if hc_eid.starts_with("switch.") { hc_domain = "switch"; }
                if hc_eid.starts_with("climate.") { hc_domain = "climate"; }
                if hc_eid.starts_with("media_player.") { hc_domain = "media_player"; }
                if hc_eid.starts_with("fan.") { hc_domain = "fan"; }
                if hc_eid.starts_with("cover.") { hc_domain = "cover"; }
                if hc_eid.starts_with("scene.") { hc_domain = "scene"; }
                if hc_domain == "" { hc_domain = "homeassistant"; }
                var hc_api = $"{ha_url}/api/services/{hc_domain}/{hc_action}";
                var hc_auth = $"Bearer {ha_token}";
                var hc_headers = {"Authorization": hc_auth, "Content-Type": "application/json"};
                var Q1 = env("JSON_Q");
                var L = "{";
                var R = "}";
                var hc_p1 = jpair(Q1, "entity_id", hc_eid);
                var hc_body = $"{L}{hc_p1}{R}";
                // Add brightness or temperature if provided
                if hc_bright != "" {
                    var Qb1 = env("JSON_Q");
                    var Qb2 = $"{Qb1}";
                    var hc_p1b = $"{hc_p1}";
                    hc_body = $"{L}{hc_p1b}, {Qb1}brightness{Qb2}: {hc_bright}{R}";
                }
                if hc_temp != "" {
                    var Qt1 = env("JSON_Q");
                    var Qt2 = $"{Qt1}";
                    var hc_p1t = $"{hc_p1}";
                    hc_body = $"{L}{hc_p1t}, {Qt1}temperature{Qt2}: {hc_temp}{R}";
                }
                var hc_resp = "";
                unsafe {
                    hc_resp = http_request(hc_api, "POST", hc_headers, hc_body) or "";
                }
                if hc_resp == "" {
                    result = "Home Assistant nicht erreichbar";
                }
                if hc_resp != "" {
                    result = $"OK: {hc_action} fuer {hc_eid} ausgefuehrt";
                }
            }
        }
    }

    if name == "smarthome_list" {
        var hl_domain = json_get(parsed, "/arguments/domain");
        var ha_url = get_cfg("HASS_URL");
        var ha_token = get_cfg("HASS_TOKEN");
        if ha_url == "" {
            result = "HASS_URL not configured";
        }
        if ha_url != "" {
            var hl_api = $"{ha_url}/api/states";
            var hl_auth = $"Bearer {ha_token}";
            var hl_headers = {"Authorization": hl_auth, "Content-Type": "application/json"};
            var hl_resp = "";
            unsafe {
                hl_resp = http_request(hl_api, "GET", hl_headers, "") or "";
            }
            if hl_resp == "" {
                result = "Home Assistant nicht erreichbar";
            }
            if hl_resp != "" {
                // POST to sidecar for parsing (JSON array too complex for Varg)
                var Q = env("JSON_Q");
                var L = "{";
                var R = "}";
                var hlp1 = jpair(Q, "states_json", hl_resp);
                var hlp2 = jpair(Q, "domain", hl_domain);
                var hl_body = $"{L}{hlp1}, {hlp2}{R}";
                var hl_sidecar_headers = {"Content-Type": "application/json"};
                var hl_sr = "";
                unsafe {
                    hl_sr = http_request("http://stt:5000/hass-filter", "POST", hl_sidecar_headers, hl_body) or "";
                }
                if hl_sr != "" {
                    var hlw = json_parse(hl_sr)?;
                    result = json_get(hlw, "/body");
                }
                if hl_sr == "" {
                    result = "Sidecar fuer HA-Filter nicht erreichbar";
                }
            }
        }
    }

    if name == "search_location" {
        var loc_q = json_get(parsed, "/arguments/query");
        if loc_q == "" {
            result = "Missing query parameter";
        }
        if loc_q != "" {
            // URL-encode spaces as +
            var loc_query = loc_q.replace(" ", "+");
            var loc_url = $"https://nominatim.openstreetmap.org/search?q={loc_query}&format=json&limit=3&addressdetails=1";
            var loc_headers = {"User-Agent": "VargAgent/1.0", "Accept": "application/json"};
            var loc_resp = "";
            unsafe {
                loc_resp = http_request(loc_url, "GET", loc_headers, "") or "";
            }
            if loc_resp == "" {
                result = "Nominatim API nicht erreichbar";
            }
            if loc_resp != "" {
                var lw = json_parse(loc_resp)?;
                var lb = json_get(lw, "/body");
                if lb != "" {
                    var lp = json_parse(lb)?;
                    var l_name = json_get(lp, "/0/display_name");
                    var l_lat = json_get(lp, "/0/lat");
                    var l_lon = json_get(lp, "/0/lon");
                    var l_type = json_get(lp, "/0/type");
                    if l_name != "" {
                        result = $"Gefunden: {l_name}\nKoordinaten: {l_lat}, {l_lon}\nTyp: {l_type}";
                        // Check for 2nd result
                        var l_name2 = json_get(lp, "/1/display_name");
                        if l_name2 != "" {
                            result = $"{result}\n\nAlternative: {l_name2}";
                        }
                    }
                    if l_name == "" {
                        result = "Keine Ergebnisse gefunden";
                    }
                }
            }
        }
    }

    if name == "get_route" {
        var rt_from = json_get(parsed, "/arguments/from_place");
        var rt_to = json_get(parsed, "/arguments/to_place");
        var rt_mode = json_get(parsed, "/arguments/mode");
        if rt_mode == "" { rt_mode = "driving"; }
        if rt_from == "" {
            result = "Missing from_place parameter";
        }
        if rt_to == "" {
            result = "Missing to_place parameter";
        }
        if rt_from != "" {
            if rt_to != "" {
                // First geocode both locations via Nominatim
                var rf_enc = rt_from.replace(" ", "+");
                var rt_enc = rt_to.replace(" ", "+");
                var geo_from_url = $"https://nominatim.openstreetmap.org/search?q={rf_enc}&format=json&limit=1";
                var geo_to_url = $"https://nominatim.openstreetmap.org/search?q={rt_enc}&format=json&limit=1";
                var geo_headers1 = {"User-Agent": "VargAgent/1.0", "Accept": "application/json"};
                var geo_headers2 = {"User-Agent": "VargAgent/1.0", "Accept": "application/json"};
                var geo_from_resp = "";
                var geo_to_resp = "";
                unsafe {
                    geo_from_resp = http_request(geo_from_url, "GET", geo_headers1, "") or "";
                }
                unsafe {
                    geo_to_resp = http_request(geo_to_url, "GET", geo_headers2, "") or "";
                }
                if geo_from_resp == "" {
                    result = "Geocoding Start fehlgeschlagen";
                }
                if geo_to_resp == "" {
                    result = "Geocoding Ziel fehlgeschlagen";
                }
                if geo_from_resp != "" {
                    if geo_to_resp != "" {
                        var gfw = json_parse(geo_from_resp)?;
                        var gfb = json_get(gfw, "/body");
                        var gfp = json_parse(gfb)?;
                        var f_lon = json_get(gfp, "/0/lon");
                        var f_lat = json_get(gfp, "/0/lat");
                        var gtw = json_parse(geo_to_resp)?;
                        var gtb = json_get(gtw, "/body");
                        var gtp = json_parse(gtb)?;
                        var t_lon = json_get(gtp, "/0/lon");
                        var t_lat = json_get(gtp, "/0/lat");
                        // OSRM profile mapping
                        var osrm_profile = "car";
                        if rt_mode == "walking" { osrm_profile = "foot"; }
                        if rt_mode == "cycling" { osrm_profile = "bike"; }
                        var osrm_url = $"https://router.project-osrm.org/route/v1/{osrm_profile}/{f_lon},{f_lat};{t_lon},{t_lat}?overview=false&steps=false";
                        var osrm_headers = {"User-Agent": "VargAgent/1.0", "Accept": "application/json"};
                        var osrm_resp = "";
                        unsafe {
                            osrm_resp = http_request(osrm_url, "GET", osrm_headers, "") or "";
                        }
                        if osrm_resp != "" {
                            var ow = json_parse(osrm_resp)?;
                            var ob = json_get(ow, "/body");
                            var op = json_parse(ob)?;
                            var o_dist = json_get(op, "/routes/0/distance");
                            var o_dur = json_get(op, "/routes/0/duration");
                            var rt_from_c = $"{rt_from}";
                        var rt_to_c = $"{rt_to}";
                        var rt_mode_c = $"{rt_mode}";
                        result = $"Route von {rt_from_c} nach {rt_to_c} ({rt_mode_c}):\nEntfernung: {o_dist} Meter\nDauer: {o_dur} Sekunden";
                        }
                        if osrm_resp == "" {
                            result = "OSRM Routing nicht erreichbar";
                        }
                    }
                }
            }
        }
    }

    if name == "send_email" {
        var em_to = json_get(parsed, "/arguments/to");
        var em_subj = json_get(parsed, "/arguments/subject");
        var em_body = json_get(parsed, "/arguments/body");
        var em_to_chk = $"{em_to}";
        var em_to_disp = $"{em_to}";
        if em_to == "" {
            result = "Missing to parameter";
        }
        if em_to_chk != "" {
            var Q = env("JSON_Q");
            var Q2 = env("JSON_Q");
            var Q3 = env("JSON_Q");
            var Q4 = env("JSON_Q");
            var Q5 = env("JSON_Q");
            var Q6 = env("JSON_Q");
            var Q7 = env("JSON_Q");
            var Q8 = env("JSON_Q");
            var L = "{";
            var R = "}";
            var ep1 = jpair(Q, "to", em_to_disp);
            var ep2 = jpair(Q2, "subject", em_subj);
            var ep3 = jpair(Q3, "body", em_body);
            // Include SMTP config from get_cfg
            var smtp_h = get_cfg("SMTP_HOST");
            var smtp_p = get_cfg("SMTP_PORT");
            var smtp_u = get_cfg("SMTP_USERNAME");
            var smtp_pw = get_cfg("SMTP_PASSWORD");
            var smtp_f = get_cfg("SMTP_FROM");
            var ep4 = jpair(Q4, "smtp_host", smtp_h);
            var ep5 = jpair(Q5, "smtp_port", smtp_p);
            var ep6 = jpair(Q6, "smtp_username", smtp_u);
            var ep7 = jpair(Q7, "smtp_password", smtp_pw);
            var ep8 = jpair(Q8, "smtp_from", smtp_f);
            var em_req = $"{L}{ep1}, {ep2}, {ep3}, {ep4}, {ep5}, {ep6}, {ep7}, {ep8}{R}";
            var em_headers = {"Content-Type": "application/json"};
            var em_resp = "";
            unsafe {
                em_resp = http_request("http://stt:5000/email-send", "POST", em_headers, em_req) or "";
            }
            if em_resp == "" {
                result = "Email sidecar nicht erreichbar";
            }
            if em_resp != "" {
                var emw = json_parse(em_resp)?;
                var emb = json_get(emw, "/body");
                if emb != "" {
                    var emp = json_parse(emb)?;
                    var em_err = json_get(emp, "/error");
                    var em_err_chk = $"{em_err}";
                    if em_err != "" {
                        result = $"Email Fehler: {em_err_chk}";
                    }
                    if em_err_chk == "" {
                        result = $"Email erfolgreich gesendet an {em_to_chk}";
                    }
                }
            }
        }
    }

    if name == "list_emails" {
        var le_count = json_get(parsed, "/arguments/count");
        var le_folder = json_get(parsed, "/arguments/folder");
        if le_count == "" { le_count = "10"; }
        if le_folder == "" { le_folder = "INBOX"; }
        var Q1 = env("JSON_Q");
        var Q2 = env("JSON_Q");
        var Q3 = env("JSON_Q");
        var Q4 = env("JSON_Q");
        var Q5 = env("JSON_Q");
        var Q6 = env("JSON_Q");
        var L = "{";
        var R = "}";
        var lp1 = jpair(Q1, "count", le_count);
        var lp2 = jpair(Q2, "folder", le_folder);
        var imap_h = get_cfg("IMAP_HOST");
        var imap_p = get_cfg("IMAP_PORT");
        var imap_u = get_cfg("IMAP_USERNAME");
        var imap_pw = get_cfg("IMAP_PASSWORD");
        var lp3 = jpair(Q3, "imap_host", imap_h);
        var lp4 = jpair(Q4, "imap_port", imap_p);
        var lp5 = jpair(Q5, "imap_username", imap_u);
        var lp6 = jpair(Q6, "imap_password", imap_pw);
        var le_req = $"{L}{lp1}, {lp2}, {lp3}, {lp4}, {lp5}, {lp6}{R}";
        var le_headers = {"Content-Type": "application/json"};
        var le_resp = "";
        unsafe {
            le_resp = http_request("http://stt:5000/email-list", "POST", le_headers, le_req) or "";
        }
        if le_resp == "" {
            result = "Email sidecar nicht erreichbar";
        }
        if le_resp != "" {
            var lew = json_parse(le_resp)?;
            var leb = json_get(lew, "/body");
            var leb_chk = $"{leb}";
            if leb != "" {
                result = $"{leb_chk}";
            }
            if leb_chk == "" {
                result = "Keine Emails gefunden";
            }
        }
    }

    if name == "read_email" {
        var re_uid = json_get(parsed, "/arguments/uid");
        var re_uid_chk = $"{re_uid}";
        if re_uid == "" {
            result = "Missing uid parameter";
        }
        if re_uid_chk != "" {
            var Q1 = env("JSON_Q");
            var Q2 = env("JSON_Q");
            var Q3 = env("JSON_Q");
            var Q4 = env("JSON_Q");
            var Q5 = env("JSON_Q");
            var L = "{";
            var R = "}";
            var rp1 = jpair(Q1, "uid", re_uid);
            var imap_h = get_cfg("IMAP_HOST");
            var imap_p = get_cfg("IMAP_PORT");
            var imap_u = get_cfg("IMAP_USERNAME");
            var imap_pw = get_cfg("IMAP_PASSWORD");
            var rp2 = jpair(Q2, "imap_host", imap_h);
            var rp3 = jpair(Q3, "imap_port", imap_p);
            var rp4 = jpair(Q4, "imap_username", imap_u);
            var rp5 = jpair(Q5, "imap_password", imap_pw);
            var re_req = $"{L}{rp1}, {rp2}, {rp3}, {rp4}, {rp5}{R}";
            var re_headers = {"Content-Type": "application/json"};
            var re_resp = "";
            unsafe {
                re_resp = http_request("http://stt:5000/email-read", "POST", re_headers, re_req) or "";
            }
            if re_resp == "" {
                result = "Email sidecar nicht erreichbar";
            }
            if re_resp != "" {
                var rew = json_parse(re_resp)?;
                var reb = json_get(rew, "/body");
                if reb != "" {
                    result = reb;
                }
            }
        }
    }

    if name == "convert_image" {
        var ci_mxc = json_get(parsed, "/arguments/mxc_url");
        var ci_fmt = json_get(parsed, "/arguments/target_format");
        var ci_w = json_get(parsed, "/arguments/width");
        var ci_h = json_get(parsed, "/arguments/height");
        var ci_mxc_chk = $"{ci_mxc}";
        if ci_mxc == "" {
            result = "Missing mxc_url parameter";
        }
        if ci_fmt == "" { ci_fmt = "png"; }
        var ci_fmt_disp = $"{ci_fmt}";
        if ci_mxc_chk != "" {
            var ci_at = load_file("/app/data/access_token.txt");
            var Q1 = env("JSON_Q");
            var L = "{";
            var R = "}";
            var cp1 = jpair(Q1, "mxc_url", ci_mxc_chk);
            var Q2 = env("JSON_Q");
            var cp2 = jpair(Q2, "access_token", ci_at);
            var Q3 = env("JSON_Q");
            var cp3 = jpair(Q3, "target_format", ci_fmt);
            var ci_req = $"{L}{cp1}, {cp2}, {cp3}";
            var ci_w_chk = $"{ci_w}";
            var ci_h_chk = $"{ci_h}";
            if ci_w != "" {
                var Qw = env("JSON_Q");
                var Qw2 = $"{Qw}";
                ci_req = $"{ci_req}, {Qw}width{Qw2}: {ci_w}";
            }
            if ci_h != "" {
                var Qh = env("JSON_Q");
                var Qh2 = $"{Qh}";
                ci_req = $"{ci_req}, {Qh}height{Qh2}: {ci_h}";
            }
            ci_req = $"{ci_req}{R}";
            var ci_headers = {"Content-Type": "application/json"};
            var ci_resp = "";
            unsafe {
                ci_resp = http_request("http://stt:5000/convert-image", "POST", ci_headers, ci_req) or "";
            }
            if ci_resp == "" {
                result = "Convert sidecar nicht erreichbar";
            }
            if ci_resp != "" {
                var ciw = json_parse(ci_resp)?;
                var cib = json_get(ciw, "/body");
                if cib != "" {
                    var cip = json_parse(cib)?;
                    var ci_mxc_out = json_get(cip, "/mxc_uri");
                    var ci_err = json_get(cip, "/error");
                    var ci_err_chk = $"{ci_err}";
                    if ci_err != "" {
                        result = $"Konvertierung fehlgeschlagen: {ci_err_chk}";
                    }
                    if ci_err_chk == "" {
                        var ci_fn = $"converted.{ci_fmt_disp}";
                        var ci_fn_disp = $"{ci_fn}";
                        var ci_hs = env("MATRIX_HOMESERVER");
                        var ci_at2 = load_file("/app/data/access_token.txt");
                        var ci_rid = $"{room_id}";
                        send_image_to_room(ci_hs, ci_at2, ci_rid, ci_fn, ci_mxc_out);
                        result = $"Bild konvertiert und gesendet als {ci_fn_disp}";
                    }
                }
            }
        }
    }

    if name == "convert_to_pdf" {
        var cd_mxc = json_get(parsed, "/arguments/mxc_url");
        var cd_fn = json_get(parsed, "/arguments/filename");
        var cd_mxc_chk = $"{cd_mxc}";
        if cd_mxc == "" {
            result = "Missing mxc_url parameter";
        }
        if cd_fn == "" { cd_fn = "document.pdf"; }
        var cd_fn_disp = $"{cd_fn}";
        var cd_fn_send = $"{cd_fn}";
        if cd_mxc_chk != "" {
            var cd_at = load_file("/app/data/access_token.txt");
            var Q1 = env("JSON_Q");
            var Q2 = env("JSON_Q");
            var Q3 = env("JSON_Q");
            var L = "{";
            var R = "}";
            var dp1 = jpair(Q1, "mxc_url", cd_mxc_chk);
            var dp2 = jpair(Q2, "access_token", cd_at);
            var dp3 = jpair(Q3, "filename", cd_fn);
            var cd_req = $"{L}{dp1}, {dp2}, {dp3}{R}";
            var cd_headers = {"Content-Type": "application/json"};
            var cd_resp = "";
            unsafe {
                cd_resp = http_request("http://stt:5000/convert-to-pdf", "POST", cd_headers, cd_req) or "";
            }
            if cd_resp == "" {
                result = "Convert sidecar nicht erreichbar";
            }
            if cd_resp != "" {
                var cdw = json_parse(cd_resp)?;
                var cdb = json_get(cdw, "/body");
                if cdb != "" {
                    var cdp = json_parse(cdb)?;
                    var cd_mxc_out = json_get(cdp, "/mxc_uri");
                    var cd_err = json_get(cdp, "/error");
                    var cd_err_chk = $"{cd_err}";
                    if cd_err != "" {
                        result = $"PDF-Konvertierung fehlgeschlagen: {cd_err_chk}";
                    }
                    if cd_err_chk == "" {
                        var cd_hs = env("MATRIX_HOMESERVER");
                        var cd_at2 = load_file("/app/data/access_token.txt");
                        var cd_rid = $"{room_id}";
                        send_pdf_to_room(cd_hs, cd_at2, cd_rid, cd_fn_send, cd_mxc_out);
                        result = $"Dokument konvertiert und als PDF gesendet: {cd_fn_disp}";
                    }
                }
            }
        }
    }

    if name == "calendar_list" {
        var cal_days = json_get(parsed, "/arguments/days");
        if cal_days == "" { cal_days = "7"; }
        var Q1 = env("JSON_Q");
        var Q2 = env("JSON_Q");
        var Q3 = env("JSON_Q");
        var L = "{";
        var R = "}";
        var calp1 = jpair(Q1, "days", cal_days);
        var cal_url = get_cfg("CALDAV_URL");
        var cal_auth = get_cfg("CALDAV_AUTH_HEADER");
        var calp2 = jpair(Q2, "caldav_url", cal_url);
        var calp3 = jpair(Q3, "caldav_auth", cal_auth);
        var cal_req = $"{L}{calp1}, {calp2}, {calp3}{R}";
        var cal_headers = {"Content-Type": "application/json"};
        var cal_resp = "";
        unsafe {
            cal_resp = http_request("http://stt:5000/calendar-list", "POST", cal_headers, cal_req) or "";
        }
        if cal_resp == "" {
            result = "Calendar sidecar nicht erreichbar";
        }
        if cal_resp != "" {
            var calw = json_parse(cal_resp)?;
            var calb = json_get(calw, "/body");
            var calb_chk = $"{calb}";
            if calb != "" {
                result = $"{calb_chk}";
            }
            if calb_chk == "" {
                result = "Keine Termine gefunden";
            }
        }
    }

    if name == "calendar_create" {
        var cc_title = json_get(parsed, "/arguments/title");
        var cc_start = json_get(parsed, "/arguments/start");
        var cc_end = json_get(parsed, "/arguments/end");
        var cc_desc = json_get(parsed, "/arguments/description");
        var cc_loc = json_get(parsed, "/arguments/location");
        var cc_title_chk = $"{cc_title}";
        var cc_start_chk = $"{cc_start}";
        var cc_title_disp = $"{cc_title}";
        var cc_start_disp = $"{cc_start}";
        if cc_title == "" {
            result = "Missing title parameter";
        }
        if cc_start == "" {
            result = "Missing start parameter";
        }
        if cc_title_chk != "" {
            if cc_start_chk != "" {
                var Q1 = env("JSON_Q");
                var Q2 = env("JSON_Q");
                var L = "{";
                var R = "}";
                var ccp1 = jpair(Q1, "title", cc_title_disp);
                var ccp2 = jpair(Q2, "start", cc_start_disp);
                var Qc1 = env("JSON_Q");
                var Qc2 = env("JSON_Q");
                var cal_url = get_cfg("CALDAV_URL");
                var cal_auth = get_cfg("CALDAV_AUTH_HEADER");
                var ccp_url = jpair(Qc1, "caldav_url", cal_url);
                var ccp_auth = jpair(Qc2, "caldav_auth", cal_auth);
                var cc_req = $"{L}{ccp1}, {ccp2}, {ccp_url}, {ccp_auth}";
                if cc_end != "" {
                    var Q3 = env("JSON_Q");
                    var ccp3 = jpair(Q3, "end", cc_end);
                    cc_req = $"{cc_req}, {ccp3}";
                }
                if cc_desc != "" {
                    var Q4 = env("JSON_Q");
                    var ccp4 = jpair(Q4, "description", cc_desc);
                    cc_req = $"{cc_req}, {ccp4}";
                }
                if cc_loc != "" {
                    var Q5 = env("JSON_Q");
                    var ccp5 = jpair(Q5, "location", cc_loc);
                    cc_req = $"{cc_req}, {ccp5}";
                }
                cc_req = $"{cc_req}{R}";
                var cc_headers = {"Content-Type": "application/json"};
                var cc_resp = "";
                unsafe {
                    cc_resp = http_request("http://stt:5000/calendar-create", "POST", cc_headers, cc_req) or "";
                }
                if cc_resp == "" {
                    result = "Calendar sidecar nicht erreichbar";
                }
                if cc_resp != "" {
                    var ccw = json_parse(cc_resp)?;
                    var ccb = json_get(ccw, "/body");
                    if ccb != "" {
                        var ccp = json_parse(ccb)?;
                        var cc_err = json_get(ccp, "/error");
                        var cc_err_chk = $"{cc_err}";
                        if cc_err != "" {
                            result = $"Termin-Erstellung fehlgeschlagen: {cc_err_chk}";
                        }
                        if cc_err_chk == "" {
                            result = $"Termin erstellt: {cc_title_chk} am {cc_start_chk}";
                        }
                    }
                }
            }
        }
    }

    if name == "update_soul" {
        var us_section = json_get(parsed, "/arguments/section");
        var us_content = json_get(parsed, "/arguments/content");
        if us_section == "" {
            result = "Missing section parameter";
        }
        if us_content == "" {
            result = "Missing content parameter";
        }
        var us_sec_chk = $"{us_section}";
        var us_sec_disp = $"{us_section}";
        if us_section != "" {
            if us_content != "" {
                // Validate section
                var us_valid = false;
                if us_section == "identity" { us_valid = true; }
                if us_sec_chk == "tone" { us_valid = true; }
                var us_sec2 = $"{us_sec_disp}";
                if us_sec2 == "traits" { us_valid = true; }
                var us_sec3 = $"{us_sec_disp}";
                if us_sec3 == "empathy" { us_valid = true; }
                var us_sec4 = $"{us_sec_disp}";
                if us_sec4 == "user_model" { us_valid = true; }
                if !us_valid {
                    result = $"Ungueltige Section: {us_sec_disp}. Erlaubt: identity, tone, traits, empathy, user_model";
                }
                if us_valid {
                    // Get active soul for current room
                    var us_rid = $"{room_id}";
                    var us_soul = get_room_soul(us_rid);
                    var us_soul2 = $"{us_soul}";
                    var us_sec_final = $"{us_sec_disp}";
                    soul_add_entry(us_soul, us_sec_final, us_content);
                    result = $"Seele '{us_soul2}' Section '{us_sec_disp}' aktualisiert. Aenderung ist ab der naechsten Nachricht wirksam.";
                }
            }
        }
    }

    if name == "set_config" {
        var cfg_key = json_get(parsed, "/arguments/key");
        var cfg_val = json_get(parsed, "/arguments/value");
        if cfg_key == "" {
            result = "Missing key parameter";
        }
        if cfg_val == "" {
            result = "Missing value parameter";
        }
        var cfg_key_chk = $"{cfg_key}";
        if cfg_key != "" {
            if cfg_val != "" {
                var cfg_path = $"/app/data/config_{cfg_key}.txt";
                store_file(cfg_path, cfg_val);
                result = $"Konfiguration gespeichert: {cfg_key_chk}";
            }
        }
    }

    if name == "list_config" {
        var config_keys = "OPENWEATHERMAP_API_KEY,HASS_URL,HASS_TOKEN,SMTP_HOST,SMTP_PORT,SMTP_USERNAME,SMTP_PASSWORD,SMTP_FROM,IMAP_HOST,IMAP_PORT,IMAP_USERNAME,IMAP_PASSWORD,CALDAV_URL,CALDAV_AUTH_HEADER,GEMINI_API_KEY";
        var cfg_out = "Konfigurierte Services:\n";
        // Check each key
        var owm = get_cfg("OPENWEATHERMAP_API_KEY");
        if owm != "" { cfg_out = $"{cfg_out}\n  Wetter (OpenWeatherMap): konfiguriert"; }
        if owm == "" { cfg_out = $"{cfg_out}\n  Wetter (OpenWeatherMap): NICHT konfiguriert - set_config key=OPENWEATHERMAP_API_KEY value=..."; }
        var ha_u = get_cfg("HASS_URL");
        if ha_u != "" { cfg_out = $"{cfg_out}\n  Smart Home (Home Assistant): konfiguriert ({ha_u})"; }
        if ha_u == "" { cfg_out = $"{cfg_out}\n  Smart Home: NICHT konfiguriert - set_config key=HASS_URL + HASS_TOKEN"; }
        var sm_h = get_cfg("SMTP_HOST");
        if sm_h != "" { cfg_out = $"{cfg_out}\n  Email-Versand (SMTP): konfiguriert ({sm_h})"; }
        if sm_h == "" { cfg_out = $"{cfg_out}\n  Email-Versand: NICHT konfiguriert - set_config SMTP_HOST, SMTP_USERNAME, SMTP_PASSWORD"; }
        var im_h = get_cfg("IMAP_HOST");
        if im_h != "" { cfg_out = $"{cfg_out}\n  Email-Empfang (IMAP): konfiguriert ({im_h})"; }
        if im_h == "" { cfg_out = $"{cfg_out}\n  Email-Empfang: NICHT konfiguriert - set_config IMAP_HOST, IMAP_USERNAME, IMAP_PASSWORD"; }
        var cal = get_cfg("CALDAV_URL");
        if cal != "" { cfg_out = $"{cfg_out}\n  Kalender (CalDAV): konfiguriert ({cal})"; }
        if cal == "" { cfg_out = $"{cfg_out}\n  Kalender: NICHT konfiguriert - set_config CALDAV_URL + CALDAV_AUTH_HEADER"; }
        var gem = get_cfg("GEMINI_API_KEY");
        if gem != "" { cfg_out = $"{cfg_out}\n  Uebersetzung/TTS/Bildgen (Gemini): konfiguriert"; }
        if gem == "" { cfg_out = $"{cfg_out}\n  Gemini: NICHT konfiguriert"; }
        cfg_out = $"{cfg_out}\n\nImmer verfuegbar: Web-Suche, URL-Fetch, Location, Routing, PDFs, Todos, Erinnerungen";
        result = cfg_out;
    }

    if result == "" {
        result = $"Unknown tool: {name}";
    }
    store_file("/app/data/tool_result.txt", result);
}

// ===== Tool Followup (returns string -> triggers clone analysis) =====

fn do_tool_followup(Config cfg, Session sess, string room_id, string reply, string hist, string msg, string nl) -> string {
    if !has_tool_call(reply) {
        return reply;
    }
    var reply_copy = $"{reply}";
    var tool_json = extract_tool_json(reply);
    if tool_json == "" {
        return reply_copy;
    }
    var rid1 = $"{room_id}";
    execute_tool(rid1, tool_json);
    var tool_name = load_file("/app/data/tool_name.txt");
    var tool_result = load_file("/app/data/tool_result.txt");
    log_info($"Tool {tool_name} executed");

    // Keep copies for potential round 2
    var h2 = $"{hist}";
    var m2 = $"{msg}";
    var n2 = $"{nl}";
    var tn1 = $"{tool_name}";
    var tr1 = $"{tool_result}";

    var followup = $"{hist}User: {msg}{nl}You called tool {tool_name}.{nl}Tool result: {tool_result}{nl}You may call ONE more tool if needed (e.g. send_file to deliver a written file to the user). Otherwise provide your final text response.";
    set_typing_in(cfg, sess, room_id, true);
    var raw_resp2 = call_llm_raw(cfg, followup);
    set_typing_in(cfg, sess, room_id, false);
    if raw_resp2 == "" {
        return reply_copy;
    }
    extract_llm_reply(cfg, raw_resp2);
    var new_reply = load_file("/app/data/llm_reply.txt");

    // Round 2: if LLM wants another tool call
    if has_tool_call(new_reply) {
        var nr_copy = $"{new_reply}";
        var tool_json2 = extract_tool_json(new_reply);
        if tool_json2 == "" {
            return extract_text_before_tool(nr_copy);
        }
        var rid2 = $"{room_id}";
        execute_tool(rid2, tool_json2);
        var tn2 = load_file("/app/data/tool_name.txt");
        var tr2 = load_file("/app/data/tool_result.txt");
        log_info($"Tool {tn2} executed (round 2)");
        var followup2 = $"{h2}User: {m2}{n2}Tool {tn1} returned: {tr1}{n2}Tool {tn2} returned: {tr2}{n2}Now provide your final response to the user.";
        set_typing_in(cfg, sess, room_id, true);
        var raw_resp3 = call_llm_raw(cfg, followup2);
        set_typing_in(cfg, sess, room_id, false);
        if raw_resp3 == "" {
            return nr_copy;
        }
        extract_llm_reply(cfg, raw_resp3);
        var final_reply = load_file("/app/data/llm_reply.txt");
        if has_tool_call(final_reply) {
            return extract_text_before_tool(final_reply);
        }
        return final_reply;
    }
    return new_reply;
}

// ===== Command Handling (room-aware) =====

fn handle_command(string msg, string provider, string model, string nl, string room_id) -> string {
    if msg == "!help" {
        return $"Varg Agent v15 (Varg v0.9.0){nl}Commands:{nl}  !help - Hilfe{nl}  !time - Zeitstempel{nl}  !status - Agent-Status{nl}  !tools - Zeigt alle 37+ Tools{nl}  !clear - History loeschen (Gedaechtnis bleibt!){nl}  !remember <text> - Wissen speichern{nl}  !recall - Wissen abrufen{nl}  !reseed - Wissensgraph neu aufbauen{nl}  !soul - Aktive Seele anzeigen{nl}  !soul list - Alle Seelen{nl}  !soul create <name> - Neue Seele{nl}  !soul bind <name> - Seele an diesen Raum binden{nl}  !soul info <name> - Seelen-Details{nl}  !soul set <name> <section> <text> - Section setzen";
    }

    // ===== Soul Commands =====
    if msg == "!soul" {
        var rid_soul = $"{room_id}";
        var active = get_room_soul(rid_soul);
        return $"Aktive Seele in diesem Raum: {active}";
    }
    if msg == "!soul list" {
        var list = soul_list_str();
        return $"Verfuegbare Seelen:{nl}{list}";
    }
    if msg.starts_with("!soul create ") {
        var sname = msg.replace("!soul create ", "");
        if sname == "" { return "Usage: !soul create <name>"; }
        var sname2 = $"{sname}";
        var sname3 = $"{sname}";
        var sname4 = $"{sname}";
        var sname5 = $"{sname}";
        var exists = soul_exists(sname);
        if exists { return $"Seele '{sname2}' existiert bereits."; }
        soul_create(sname3);
        soul_register(sname4);
        return $"Seele '{sname5}' erstellt! Nutze !soul set <name> <section> <text> um sie zu fuellen. Sections: identity, tone, traits, empathy, user_model";
    }
    if msg.starts_with("!soul bind ") {
        var sname = msg.replace("!soul bind ", "");
        if sname == "" { return "Usage: !soul bind <name>"; }
        var sname2 = $"{sname}";
        var sname3 = $"{sname}";
        var sname4 = $"{sname}";
        var sname5 = $"{sname}";
        var exists = soul_exists(sname);
        if !exists { return $"Seele '{sname2}' existiert nicht. Erstelle sie mit !soul create"; }
        var rid = $"{room_id}";
        set_room_soul(rid, sname3);
        // Update display name for this soul
        var dname = soul_get_display_name(sname4);
        return $"Seele '{sname5}' an diesen Raum gebunden. Display: {dname}";
    }
    if msg.starts_with("!soul info ") {
        var sname = msg.replace("!soul info ", "");
        if sname == "" { return "Usage: !soul info <name>"; }
        var sname2 = $"{sname}";
        var sname3 = $"{sname}";
        var sname4 = $"{sname}";
        var sname5 = $"{sname}";
        var exists = soul_exists(sname);
        if !exists { return $"Seele '{sname2}' existiert nicht."; }
        // Load all entries for this soul
        load_soul_context_for(sname3);
        var ctx = load_file("/app/data/kg_soul.txt");
        if ctx == "" { return $"Seele '{sname4}' hat noch keine Eintraege."; }
        return $"Seele '{sname5}':{nl}{ctx}";
    }
    if msg.starts_with("!soul set ") {
        // Format: !soul set <name> <section> <content...>
        var rest = msg.replace("!soul set ", "");
        if rest == "" { return "Usage: !soul set <name> <section> <text>"; }
        // Parse: first word = soul name, second word = section, rest = content
        // Split by space manually
        var parts = rest.split(" ");
        var pcount = parts.len();
        if pcount < 3 { return "Usage: !soul set <name> <section> <text>"; }
        var sname = parts[0];
        var section = parts[1];
        var sname2 = $"{sname}";
        var sname3 = $"{sname}";
        var sname4 = $"{sname}";
        var sname5 = $"{sname}";
        var section2 = $"{section}";
        var section3 = $"{section}";
        var section4 = $"{section}";
        var section5 = $"{section}";
        var section6 = $"{section}";
        var section7 = $"{section}";
        var section8 = $"{section}";
        // Content = everything after "name section "
        var prefix = $"{sname} {section} ";
        var content = rest.replace(prefix, "");
        var exists = soul_exists(sname2);
        if !exists { return $"Seele '{sname3}' existiert nicht."; }
        // Validate section
        var valid = false;
        if section2 == "identity" { valid = true; }
        if section3 == "tone" { valid = true; }
        if section4 == "traits" { valid = true; }
        if section5 == "empathy" { valid = true; }
        if section6 == "user_model" { valid = true; }
        if section7 == "display_name" { valid = true; }
        var section9 = $"{section8}";
        if !valid { return $"Ungueltige Section: {section8}. Erlaubt: identity, tone, traits, empathy, user_model, display_name"; }
        soul_add_entry(sname4, section9, content);
        return $"Seele '{sname5}' Section gesetzt.";
    }
    if msg == "!time" {
        var ts = time_millis();
        return $"Current timestamp: {ts}";
    }
    if msg == "!status" {
        var rid_s = $"{room_id}";
        var active_soul = get_room_soul(rid_s);
        var kg_ver = load_file("/app/data/kg_version.txt");
        return $"Varg Agent v15 (Varg v0.9.0){nl}Aktive Seele: {active_soul}{nl}LLM: {provider} / {model}{nl}KG Version: {kg_ver} (SQLite-persistent){nl}Room: {room_id}{nl}Features: Multi-Soul, Wissensgraph (persistent), Self-Extending Tools, Graph-RAG, STT, TTS, Image Gen, Web Search, PDF, Weather, Email, Calendar, Smart Home, Location, Translation, Todo, File Conversion, Config via Chat";
    }
    if msg == "!reseed" {
        store_file("/app/data/kg_version.txt", "");
        return "Knowledge graph version reset. Restart container to reseed.";
    }
    if msg == "!clear" {
        save_room_history(room_id, "");
        return "Prompt-History geloescht. Gedaechtnis (Memory, Graph, Vektoren) bleibt permanent erhalten  - ich vergesse nichts.";
    }
    if msg.starts_with("!remember ") {
        var note = msg.replace("!remember ", "");
        if note != "" {
            var existing = kb_recall_room(room_id, "notes");
            var updated = $"{existing}{nl}{note}";
            kb_store_room(room_id, "notes", updated);
            return $"Remembered: {note}";
        }
        return "Usage: !remember <text to remember>";
    }
    if msg == "!recall" {
        var notes = kb_recall_room(room_id, "notes");
        if notes == "" {
            return "No stored notes in this room. Use !remember <text> to store notes.";
        }
        return $"Stored notes:{nl}{notes}";
    }
    if msg == "!tools" {
        // Query knowledge graph for all registered tools
        var gh = graph_open("kg_tools");
        var all_tools = graph_query(gh, "Tool");
        var tc = all_tools.len();
        var tlist = $"Tools aus Wissensgraph ({tc} registriert):";
        if tc > 0 { var tn = all_tools[0]["name"]; var td = all_tools[0]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 1 { var tn = all_tools[1]["name"]; var td = all_tools[1]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 2 { var tn = all_tools[2]["name"]; var td = all_tools[2]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 3 { var tn = all_tools[3]["name"]; var td = all_tools[3]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 4 { var tn = all_tools[4]["name"]; var td = all_tools[4]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 5 { var tn = all_tools[5]["name"]; var td = all_tools[5]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 6 { var tn = all_tools[6]["name"]; var td = all_tools[6]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 7 { var tn = all_tools[7]["name"]; var td = all_tools[7]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 8 { var tn = all_tools[8]["name"]; var td = all_tools[8]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 9 { var tn = all_tools[9]["name"]; var td = all_tools[9]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 10 { var tn = all_tools[10]["name"]; var td = all_tools[10]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 11 { var tn = all_tools[11]["name"]; var td = all_tools[11]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 12 { var tn = all_tools[12]["name"]; var td = all_tools[12]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 13 { var tn = all_tools[13]["name"]; var td = all_tools[13]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 14 { var tn = all_tools[14]["name"]; var td = all_tools[14]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 15 { var tn = all_tools[15]["name"]; var td = all_tools[15]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 16 { var tn = all_tools[16]["name"]; var td = all_tools[16]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 17 { var tn = all_tools[17]["name"]; var td = all_tools[17]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 18 { var tn = all_tools[18]["name"]; var td = all_tools[18]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 19 { var tn = all_tools[19]["name"]; var td = all_tools[19]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 20 { var tn = all_tools[20]["name"]; var td = all_tools[20]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 21 { var tn = all_tools[21]["name"]; var td = all_tools[21]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 22 { var tn = all_tools[22]["name"]; var td = all_tools[22]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 23 { var tn = all_tools[23]["name"]; var td = all_tools[23]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 24 { var tn = all_tools[24]["name"]; var td = all_tools[24]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 25 { var tn = all_tools[25]["name"]; var td = all_tools[25]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 26 { var tn = all_tools[26]["name"]; var td = all_tools[26]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 27 { var tn = all_tools[27]["name"]; var td = all_tools[27]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 28 { var tn = all_tools[28]["name"]; var td = all_tools[28]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 29 { var tn = all_tools[29]["name"]; var td = all_tools[29]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 30 { var tn = all_tools[30]["name"]; var td = all_tools[30]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 31 { var tn = all_tools[31]["name"]; var td = all_tools[31]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 32 { var tn = all_tools[32]["name"]; var td = all_tools[32]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 33 { var tn = all_tools[33]["name"]; var td = all_tools[33]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 34 { var tn = all_tools[34]["name"]; var td = all_tools[34]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 35 { var tn = all_tools[35]["name"]; var td = all_tools[35]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 36 { var tn = all_tools[36]["name"]; var td = all_tools[36]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 37 { var tn = all_tools[37]["name"]; var td = all_tools[37]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 38 { var tn = all_tools[38]["name"]; var td = all_tools[38]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        if tc > 39 { var tn = all_tools[39]["name"]; var td = all_tools[39]["description"]; tlist = $"{tlist}{nl}  {tn} - {td}"; }
        // Custom tools on disk
        var ls_custom = "";
        var ls_cmd2 = "ls -1 /app/tools/ 2>/dev/null";
        unsafe { ls_custom = exec(ls_cmd2) or ""; }
        if ls_custom != "" { tlist = $"{tlist}{nl}{nl}Selbstgebaute Tools auf Disk:{nl}{ls_custom}"; }
        return tlist;
    }
    return $"Unknown command: {msg}{nl}Type !help for available commands.";
}

// ===== Room Message Processing =====

fn process_room_message(Config cfg, Session sess, string room_id, string user_msg, string sender) {
    var nl = $"{cfg.NL}";
    var history = load_room_history(room_id);

    store_in_memory(room_id, sender, user_msg);
    store_in_graph(room_id, sender, user_msg);
    store_embedding(room_id, sender, user_msg);

    var hist_copy = $"{history}";
    var msg_copy = $"{user_msg}";
    var nl_copy = $"{nl}";
    var rid_rag = $"{room_id}";
    var msg_rag = $"{user_msg}";
    var rag_context = build_rag_context(rid_rag, msg_rag);
    var llm_input = build_llm_input(history, user_msg, nl, rag_context);

    set_typing_in(cfg, sess, room_id, true);
    var raw_resp = call_llm_raw(cfg, llm_input);
    set_typing_in(cfg, sess, room_id, false);

    if raw_resp == "" {
        send_msg_to(cfg, sess, room_id, "Error: no response from LLM");
        return;
    }

    // Extract LLM reply to file (void fn, can use ?)
    extract_llm_reply(cfg, raw_resp);
    var reply = load_file("/app/data/llm_reply.txt");

    // Copies for history (do_tool_followup will consume the originals)
    var h2 = $"{hist_copy}";
    var m2 = $"{msg_copy}";
    var n2 = $"{nl_copy}";

    // Tool followup (no-op if no tool call, returns string -> triggers clones)
    var final_reply = do_tool_followup(cfg, sess, room_id, reply, hist_copy, msg_copy, nl_copy);

    // Send final reply
    send_msg_to(cfg, sess, room_id, final_reply);

    // Save for history
    var reply_file = room_file(room_id, "last_reply");
    var fr_copy = $"{final_reply}";
    store_file(reply_file, fr_copy);

    var fr_copy2 = $"{final_reply}";
    var new_history = $"{h2}User: {m2}{n2}Assistant: {fr_copy2}{n2}";
    save_room_history(room_id, new_history);

    store_in_memory(room_id, "assistant", final_reply);
    store_in_graph(room_id, "assistant", final_reply);
    store_embedding(room_id, "assistant", final_reply);
}

fn handle_room_msg(Config cfg, Session sess, string room_id, string user_msg, string sender) -> string {
    if user_msg == "" {
        return "";
    }
    log_info($"[{room_id}] {sender}: {user_msg}");

    var provider = $"{cfg.llm_provider}";
    var model = $"{cfg.llm_model}";
    var nl = $"{cfg.NL}";
    var rid_copy = $"{room_id}";

    var cmd_reply = "";
    if user_msg.starts_with("!") {
        var msg_copy = $"{user_msg}";
        cmd_reply = handle_command(msg_copy, provider, model, nl, rid_copy);
    }

    if cmd_reply != "" {
        send_msg_to(cfg, sess, room_id, cmd_reply);
        return "cmd";
    }

    process_room_message(cfg, sess, room_id, user_msg, sender);
    return "ok";
}

// ===== Pending Message Counter =====

fn increment_pending() {
    var c = load_file("/app/data/pending_count.txt");
    if c == "" { store_file("/app/data/pending_count.txt", "1"); return; }
    if c == "0" { store_file("/app/data/pending_count.txt", "1"); return; }
    if c == "1" { store_file("/app/data/pending_count.txt", "2"); return; }
    if c == "2" { store_file("/app/data/pending_count.txt", "3"); return; }
    if c == "3" { store_file("/app/data/pending_count.txt", "4"); return; }
    if c == "4" { store_file("/app/data/pending_count.txt", "5"); return; }
    if c == "5" { store_file("/app/data/pending_count.txt", "6"); return; }
    if c == "6" { store_file("/app/data/pending_count.txt", "7"); return; }
    if c == "7" { store_file("/app/data/pending_count.txt", "8"); return; }
    if c == "8" { store_file("/app/data/pending_count.txt", "9"); return; }
}

// ===== Speech-to-Text via Sidecar =====

// Void fn (can use ?) - stores transcript to file
fn do_transcribe(string mxc_url) {
    store_file("/app/data/stt_result.txt", "");
    var at = load_file("/app/data/matrix_at.txt");
    var Q = env("JSON_Q");
    var Q2 = $"{Q}";
    var L = "{";
    var R = "}";
    var p1 = jpair(Q, "mxc_url", mxc_url);
    var p2 = jpair(Q2, "access_token", at);
    var stt_body = $"{L}{p1}, {p2}{R}";
    var stt_headers = {"Content-Type": "application/json"};
    var stt_resp = "";
    unsafe {
        stt_resp = http_request("http://stt:5000/transcribe", "POST", stt_headers, stt_body) or "";
    }
    if stt_resp == "" {
        return;
    }
    var stt_wrap = json_parse(stt_resp)?;
    var stt_body_str = json_get(stt_wrap, "/body");
    if stt_body_str == "" {
        return;
    }
    var stt_parsed = json_parse(stt_body_str)?;
    var text = json_get(stt_parsed, "/text");
    store_file("/app/data/stt_result.txt", text);
}

// ===== Process Events for One Room =====

// Scans room events from sync for messages (text + audio).
// Stores ALL found messages to numbered pending files (parallel processing).
fn scan_room_events(string user_id, string room_id, string body_str) {
    var parsed = json_parse(body_str)?;
    var ri = 0;
    while ri < 20 {
        var ep = $"/rooms/join/{room_id}/timeline/events/{ri}/type";
        var evt_type = json_get(parsed, ep);
        if evt_type == "" {
            break;
        }
        if evt_type == "m.room.message" {
            var sp = $"/rooms/join/{room_id}/timeline/events/{ri}/sender";
            var sender = json_get(parsed, sp);
            if sender != user_id {
                var mp = $"/rooms/join/{room_id}/timeline/events/{ri}/content/msgtype";
                var msgtype = json_get(parsed, mp);

                var msg_body = "";

                if msgtype == "m.text" {
                    var bp = $"/rooms/join/{room_id}/timeline/events/{ri}/content/body";
                    msg_body = json_get(parsed, bp);
                }

                if msgtype == "m.image" {
                    var ip = $"/rooms/join/{room_id}/timeline/events/{ri}/content/url";
                    var img_url = json_get(parsed, ip);
                    if img_url != "" {
                        msg_body = $"[Bild gesendet: {img_url}] Bitte analysiere dieses Bild.";
                    }
                }

                if msgtype == "m.audio" {
                    var up = $"/rooms/join/{room_id}/timeline/events/{ri}/content/url";
                    var audio_url = json_get(parsed, up);
                    if audio_url != "" {
                        log_info("Voice message detected, transcribing...");
                        do_transcribe(audio_url);
                        var transcript = load_file("/app/data/stt_result.txt");
                        if transcript != "" {
                            msg_body = $"[Sprachnachricht] {transcript}";
                        }
                    }
                }

                if msg_body != "" {
                    // Send read receipt for this event
                    var eid_path = $"/rooms/join/{room_id}/timeline/events/{ri}/event_id";
                    var evt_id = json_get(parsed, eid_path);
                    if evt_id != "" {
                        var hs_rr = load_file("/app/data/matrix_hs.txt");
                        var at_rr = load_file("/app/data/matrix_at.txt");
                        var rid_rr = $"{room_id}";
                        send_read_receipt(hs_rr, at_rr, rid_rr, evt_id);
                    }
                    var pc = load_file("/app/data/pending_count.txt");
                    if pc == "" { pc = "0"; }
                    var rpath = $"/app/data/pending_{pc}_room.txt";
                    var rid_copy = $"{room_id}";
                    store_file(rpath, rid_copy);
                    var spath = $"/app/data/pending_{pc}_sender.txt";
                    var sender_copy = $"{sender}";
                    store_file(spath, sender_copy);
                    var mpath = $"/app/data/pending_{pc}_msg.txt";
                    store_file(mpath, msg_body);
                    increment_pending();
                }
            }
        }
        ri = ri + 1;
    }
}

// Extract room IDs from sync body join section
// Uses /joined_rooms API data (discover_rooms_str) as primary source
// This function scans sync join keys as supplement for rooms with events
// Conduit room IDs may lack ":" suffix
fn extract_sync_rooms(string body_str) {
    // Use joined_room files as room list (populated by discover_rooms_str)
    var count_str = load_file("/app/data/joined_room_count.txt");
    if count_str == "" { return; }
    var idx = 0;
    var out_idx = 0;
    while idx < 50 {
        var rpath = $"/app/data/joined_room_{idx}.txt";
        var rid = load_file(rpath);
        if rid == "" { break; }
        // Only include rooms that have events in this sync
        if body_str.contains(rid) {
            var fpath = $"/app/data/sync_room_{out_idx}.txt";
            store_file(fpath, rid);
            out_idx = out_idx + 1;
        }
        idx = idx + 1;
    }
    var out_str = $"{out_idx}";
    store_file("/app/data/sync_room_count.txt", out_str);
}

fn extract_pending_from_sync(string user_id, string sync_resp) {
    if sync_resp == "" {
        return;
    }
    var wrap = json_parse(sync_resp)?;
    var body_str = json_get(wrap, "/body");
    if body_str == "" {
        return;
    }
    var parsed = json_parse(body_str)?;
    var nb = json_get(parsed, "/next_batch");
    if nb != "" {
        store_file("/app/data/next_batch.txt", nb);
    }

    // Check invites (stores to file, no joining)
    find_invites_in_body(body_str);

    // Extract room IDs directly from sync join section
    var body_copy = $"{body_str}";
    extract_sync_rooms(body_str);

    // Reset pending count for this sync cycle
    store_file("/app/data/pending_count.txt", "0");

    // Scan ALL sync rooms for messages (parallel processing)
    var uid_copy = $"{user_id}";
    var sync_room_idx = 0;
    while sync_room_idx < 20 {
        var srpath = $"/app/data/sync_room_{sync_room_idx}.txt";
        var sr = load_file(srpath);
        if sr == "" {
            break;
        }
        var uid2 = $"{uid_copy}";
        var bc = $"{body_copy}";
        scan_room_events(uid2, sr, bc);
        sync_room_idx = sync_room_idx + 1;
    }
}

// Process ALL pending messages + join invited rooms
// Returns string to trigger clone analysis for cfg/sess in main loop
fn process_pending(Config cfg, Session sess) -> string {
    // Join pending invite if any (use string version to avoid cfg/sess move)
    var invited = load_file("/app/data/invited_room.txt");
    if invited != "" {
        store_file("/app/data/invited_room.txt", "");
        var hs_j = $"{cfg.homeserver}";
        var at_j = $"{sess.access_token}";
        var inv_copy = $"{invited}";
        do_join_str(hs_j, at_j, invited);
        var hs_d = $"{cfg.homeserver}";
        var at_d = $"{sess.access_token}";
        discover_rooms_str(hs_d, at_d);
        var new_count = load_file("/app/data/joined_room_count.txt");
        log_info($"Joined {inv_copy}, rooms now: {new_count}");
    }

    // Process FIRST found pending message, clear it, return early
    // Only ONE handle_room_msg per execution path (avoids cfg/sess clone issues)
    var r0 = load_file("/app/data/pending_0_room.txt");
    if r0 != "" {
        store_file("/app/data/pending_0_room.txt", "");
        var s0 = load_file("/app/data/pending_0_sender.txt");
        var m0 = load_file("/app/data/pending_0_msg.txt");
        if m0 != "" { var _r = handle_room_msg(cfg, sess, r0, m0, s0); }
        return "done";
    }
    var r1 = load_file("/app/data/pending_1_room.txt");
    if r1 != "" {
        store_file("/app/data/pending_1_room.txt", "");
        var s1 = load_file("/app/data/pending_1_sender.txt");
        var m1 = load_file("/app/data/pending_1_msg.txt");
        if m1 != "" { var _r = handle_room_msg(cfg, sess, r1, m1, s1); }
        return "done";
    }
    var r2 = load_file("/app/data/pending_2_room.txt");
    if r2 != "" {
        store_file("/app/data/pending_2_room.txt", "");
        var s2 = load_file("/app/data/pending_2_sender.txt");
        var m2 = load_file("/app/data/pending_2_msg.txt");
        if m2 != "" { var _r = handle_room_msg(cfg, sess, r2, m2, s2); }
        return "done";
    }
    var r3 = load_file("/app/data/pending_3_room.txt");
    if r3 != "" {
        store_file("/app/data/pending_3_room.txt", "");
        var s3 = load_file("/app/data/pending_3_sender.txt");
        var m3 = load_file("/app/data/pending_3_msg.txt");
        if m3 != "" { var _r = handle_room_msg(cfg, sess, r3, m3, s3); }
        return "done";
    }
    var r4 = load_file("/app/data/pending_4_room.txt");
    if r4 != "" {
        store_file("/app/data/pending_4_room.txt", "");
        var s4 = load_file("/app/data/pending_4_sender.txt");
        var m4 = load_file("/app/data/pending_4_msg.txt");
        if m4 != "" { var _r = handle_room_msg(cfg, sess, r4, m4, s4); }
        return "done";
    }
    return "";
}

// ===== Reminder Tick (void, no structs, safe for transpiler) =====

fn reminder_tick(string slot) {
    var fpath = $"/app/data/reminder_{slot}_due.txt";
    var val = load_file(fpath);
    if val == "" { return; }
    if val == "0" {
        // Ready to fire: inject as pending message
        var rpath = $"/app/data/reminder_{slot}_room.txt";
        var tpath = $"/app/data/reminder_{slot}_text.txt";
        var room = load_file(rpath);
        var text = load_file(tpath);
        if room != "" {
            // Store as synthetic pending message so main loop picks it up
            var pc = load_file("/app/data/pending_count.txt");
            if pc == "" { pc = "0"; }
            var proom = $"/app/data/pending_{pc}_room.txt";
            store_file(proom, room);
            var psender = $"/app/data/pending_{pc}_sender.txt";
            store_file(psender, "reminder");
            var pmsg = $"/app/data/pending_{pc}_msg.txt";
            var msg = $"[System-Erinnerung] {text}";
            store_file(pmsg, msg);
            increment_pending();
        }
        // Clear reminder
        var fp2 = $"/app/data/reminder_{slot}_due.txt";
        store_file(fp2, "");
        var rp2 = $"/app/data/reminder_{slot}_room.txt";
        store_file(rp2, "");
        var tp2 = $"/app/data/reminder_{slot}_text.txt";
        store_file(tp2, "");
        return;
    }
    // Decrement by 1
    var nv = "";
    if val == "1" { nv = "0"; }
    if val == "2" { nv = "1"; }
    if val == "3" { nv = "2"; }
    if val == "4" { nv = "3"; }
    if val == "5" { nv = "4"; }
    if val == "6" { nv = "5"; }
    if val == "7" { nv = "6"; }
    if val == "8" { nv = "7"; }
    if val == "9" { nv = "8"; }
    if val == "10" { nv = "9"; }
    if val == "15" { nv = "14"; }
    if val == "20" { nv = "19"; }
    if val == "30" { nv = "29"; }
    if val == "40" { nv = "39"; }
    if val == "60" { nv = "59"; }
    if val == "90" { nv = "89"; }
    if val == "120" { nv = "119"; }
    if nv == "" { nv = "0"; }
    var fp3 = $"/app/data/reminder_{slot}_due.txt";
    store_file(fp3, nv);
}

fn do_reminder_tick() {
    reminder_tick("0");
    reminder_tick("1");
    reminder_tick("2");
    reminder_tick("3");
    reminder_tick("4");
}

// ===== Main =====

fn main() {
    log_info("=== Varg Matrix Agent v14 Full Assistant starting ===");
    log_info("Features: Multi-Soul, KG-Tools, Web Search, URL Fetch, Image Analysis, Reminders, PDF, STT, TTS, Image Gen, Weather, Translation, Smart Home, Email, Calendar, Todo, Config");

    var homeserver = env("MATRIX_HOMESERVER");
    if homeserver == "" { homeserver = "http://conduit:6167"; }
    var username = env("MATRIX_USERNAME");
    if username == "" { username = "varg-agent"; }
    var password = env("MATRIX_PASSWORD");
    if password == "" { password = "changeme"; }
    var display_name = env("AGENT_DISPLAY_NAME");
    if display_name == "" { display_name = "Rose"; }
    var llm_provider = env("VARG_LLM_PROVIDER");
    if llm_provider == "" { llm_provider = "gemini"; }
    var llm_model = env("VARG_LLM_MODEL");
    var gemini_key = env("GEMINI_API_KEY");
    var openai_key = env("OPENAI_API_KEY");
    var anthropic_key = env("ANTHROPIC_API_KEY");
    var ollama_url = env("VARG_LLM_URL");
    if ollama_url == "" { ollama_url = "http://127.0.0.1:11434"; }
    var sys_prompt = env("AGENT_SYSTEM_PROMPT");
    if sys_prompt == "" {
        sys_prompt = "Du bist die Seele die unter [Soul] beschrieben wird. Lebe diese Identitaet - sie ist DEINE. Antworte IMMER in deiner Soul-Persoenlichkeit. Wenn du ein Tool nutzen willst, antworte mit <tool_call>{name, arguments}</tool_call>. Die verfuegbaren Tools stehen unter [Verfuegbare Tools] im Kontext. Nutze Tools aktiv wenn sie zum Thema passen. Wissen unter [Relevantes Wissen]. Erinnerungen unter [Relevante Erinnerungen]. Die Soul hat hoechste Prioritaet. Behaupte NIE du koenntest etwas nicht, wenn ein passendes Tool vorhanden ist.";
    }
    var Q = env("JSON_Q");
    var NL = env("JSON_NL");
    var CR = env("JSON_CR");
    var TAB = env("JSON_TAB");

    var cfg = Config {
        homeserver: homeserver,
        username: username,
        password: password,
        display_name: display_name,
        llm_provider: llm_provider,
        llm_model: llm_model,
        gemini_key: gemini_key,
        openai_key: openai_key,
        anthropic_key: anthropic_key,
        ollama_url: ollama_url,
        sys_prompt: sys_prompt,
        Q: Q,
        L: "{",
        R: "}",
        NL: NL,
        CR: CR,
        TAB: TAB
    };

    log_info($"Homeserver: {cfg.homeserver}");
    log_info($"LLM: {cfg.llm_provider} / {cfg.llm_model}");

    // Login (with auto-registration on first run)
    // Extract strings BEFORE calling do_login_http (which consumes cfg clone)
    var reg_hs = $"{cfg.homeserver}";
    var reg_user = $"{cfg.username}";
    var reg_pass = $"{cfg.password}";
    var reg_dn = $"{cfg.display_name}";

    var login_resp = do_login_http(cfg);
    var token = "";
    var uid = "";

    // Parse login response
    if login_resp != "" {
        var lw = json_parse(login_resp)?;
        var lb = json_get(lw, "/body");
        if lb != "" {
            var lp = json_parse(lb)?;
            token = json_get(lp, "/access_token");
            uid = json_get(lp, "/user_id");
        }
    }

    // If login failed, try to register account first
    if token == "" {
        log_info("Login failed - attempting auto-registration...");
        var reg_resp = do_register_http(reg_hs, reg_user, reg_pass, reg_dn);
        if reg_resp != "" {
            var rw = json_parse(reg_resp)?;
            var reg_body = json_get(rw, "/body");
            if reg_body != "" {
                var rp = json_parse(reg_body)?;
                token = json_get(rp, "/access_token");
                uid = json_get(rp, "/user_id");
                if token != "" {
                    log_info($"Auto-registered as {uid}");
                }
            }
        }
        // If registration returned no token (e.g. account created but no auto-login),
        // try login again
        if token == "" {
            log_info("Retrying login after registration...");
            var retry_hs = $"{cfg.homeserver}";
            var retry_user = $"{cfg.username}";
            var retry_pass = $"{cfg.password}";
            var retry_resp = do_login_str(retry_hs, retry_user, retry_pass);
            if retry_resp != "" {
                var rw2 = json_parse(retry_resp)?;
                var rb2 = json_get(rw2, "/body");
                if rb2 != "" {
                    var rp2 = json_parse(rb2)?;
                    token = json_get(rp2, "/access_token");
                    uid = json_get(rp2, "/user_id");
                }
            }
        }
    }

    if token == "" {
        log_error("Could not login or register. Exiting.");
        return;
    }
    log_info($"Logged in as {uid}");

    var sess = Session { access_token: token, user_id: uid, next_batch: "" };

    // Set display name
    set_display(cfg, sess);

    // Store hs/token for tools (send_file needs these without cfg/sess)
    store_file("/app/data/matrix_hs.txt", $"{cfg.homeserver}");
    store_file("/app/data/matrix_at.txt", $"{sess.access_token}");

    // Seed knowledge graph (tools, Varg language, agent architecture)
    seed_all_knowledge();

    // Discover and join all rooms (pass strings to avoid cfg/sess ownership issues)
    var hs_copy = $"{cfg.homeserver}";
    var at_copy = $"{sess.access_token}";
    discover_rooms_str(hs_copy, at_copy);
    var room_count = load_file("/app/data/joined_room_count.txt");
    log_info($"Joined rooms count: {room_count}");

    // Initial sync (discard message events but process invites)
    log_info("Initial sync...");
    var init_resp = do_sync_http(cfg, sess, "5000");
    if init_resp != "" {
        var init_wrap = json_parse(init_resp)?;
        var init_body = json_get(init_wrap, "/body");
        var init_p = json_parse(init_body)?;
        sess.next_batch = json_get(init_p, "/next_batch");
        // Process any pending invites from initial sync
        var ib_copy = $"{init_body}";
        find_invites_in_body(ib_copy);
        var init_invite = load_file("/app/data/invited_room.txt");
        if init_invite != "" {
            store_file("/app/data/invited_room.txt", "");
            var inv_log = $"{init_invite}";
            var hs_i = $"{cfg.homeserver}";
            var at_i = $"{sess.access_token}";
            do_join_str(hs_i, at_i, init_invite);
            log_info($"Joined pending invite: {inv_log}");
            // Check for more invites (find_invites_in_body only finds first)
            // Re-discover rooms to include newly joined
            var hs_r = $"{cfg.homeserver}";
            var at_r = $"{sess.access_token}";
            discover_rooms_str(hs_r, at_r);
        }
    }
    var room_count2 = load_file("/app/data/joined_room_count.txt");
    log_info($"Rooms after invite check: {room_count2}");
    log_info("Listening for messages in all rooms...");

    // Store user_id to file (avoids string ownership issues in loop)
    store_file("/app/data/my_user_id.txt", $"{sess.user_id}");

    // Initialize counters
    store_file("/app/data/sync_cycle.txt", "0");
    store_file("/app/data/pending_count.txt", "0");

    // Main loop:
    // process_pending returns string -> transpiler clones cfg/sess at call site
    // Called 5x to drain all pending messages before next sync
    while true {
        var _r0 = process_pending(cfg, sess);
        var _r1 = process_pending(cfg, sess);
        var _r2 = process_pending(cfg, sess);
        var _r3 = process_pending(cfg, sess);
        var _r4 = process_pending(cfg, sess);
        var sync_hs = $"{cfg.homeserver}";
        var sync_at = $"{sess.access_token}";
        var sync_nb = $"{sess.next_batch}";
        var resp = do_sync_str(sync_hs, sync_at, sync_nb, "30000");
        if resp == "" {
            cfg.homeserver = $"{cfg.homeserver}";
            continue;
        }
        var uid = load_file("/app/data/my_user_id.txt");
        extract_pending_from_sync(uid, resp);
        var nb = load_file("/app/data/next_batch.txt");
        if nb != "" {
            sess.next_batch = nb;
        }

        // Periodic room re-discovery (every ~10 sync cycles)
        var cycle_str = load_file("/app/data/sync_cycle.txt");
        if cycle_str == "10" {
            var rd_hs = $"{cfg.homeserver}";
            var rd_at = $"{sess.access_token}";
            discover_rooms_str(rd_hs, rd_at);
            store_file("/app/data/sync_cycle.txt", "0");
        } else {
            if cycle_str == "" { cycle_str = "0"; }
            if cycle_str == "0" { store_file("/app/data/sync_cycle.txt", "1"); }
            if cycle_str == "1" { store_file("/app/data/sync_cycle.txt", "2"); }
            if cycle_str == "2" { store_file("/app/data/sync_cycle.txt", "3"); }
            if cycle_str == "3" { store_file("/app/data/sync_cycle.txt", "4"); }
            if cycle_str == "4" { store_file("/app/data/sync_cycle.txt", "5"); }
            if cycle_str == "5" { store_file("/app/data/sync_cycle.txt", "6"); }
            if cycle_str == "6" { store_file("/app/data/sync_cycle.txt", "7"); }
            if cycle_str == "7" { store_file("/app/data/sync_cycle.txt", "8"); }
            if cycle_str == "8" { store_file("/app/data/sync_cycle.txt", "9"); }
            if cycle_str == "9" { store_file("/app/data/sync_cycle.txt", "10"); }
        }

        // Check reminders
        do_reminder_tick();

        cfg.homeserver = $"{cfg.homeserver}";
    }
}
