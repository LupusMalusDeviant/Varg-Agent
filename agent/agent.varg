    kg_seed_tool("generate_pdf", "Generiert ein PDF-Dokument und sendet es im Chat. Perfekt fuer Berichte, Zusammenfassungen, Listen.", "title: Dokumenttitel, sections: Array von {heading, body} Abschnitten, filename?: Dateiname (Standard: document.pdf)");
    kg_seed_tool("web_search", "Sucht im Internet nach aktuellen Informationen. Nutze dies fuer Wetter, Nachrichten, Fakten, alles was aktuelles Wissen braucht.", "query: Suchbegriff, max_results?: Anzahl Ergebnisse (Standard: 5)");
    kg_seed_tool("fetch_url", "Ruft eine Webseite ab und extrahiert den Textinhalt. Nutze dies wenn der User einen Link schickt oder du Details zu einem Suchergebnis brauchst.", "url: Die abzurufende URL, max_chars?: Maximale Textlaenge (Standard: 8000)");
    kg_seed_tool("analyze_image", "Analysiert ein Bild das der User im Chat geschickt hat. Beschreibt was auf dem Bild zu sehen ist.", "mxc_url: Die mxc:// URL des Bildes (aus der Nachricht), prompt?: Spezifische Frage zum Bild");
    kg_seed_tool("set_reminder", "Setzt eine Erinnerung die nach einer bestimmten Zeit als Nachricht im Chat erscheint. Zeitangaben relativ in Minuten.", "minutes: Minuten bis zur Erinnerung, text: Erinnerungstext");
    kg_seed_tool("tts_respond", "Spricht den Text als Sprachnachricht aus und sendet sie als Audio im Chat. Nutze dies wenn der User darum bittet vorgelesen zu bekommen oder eine Sprachantwort will.", "text: Der vorzulesende Text, filename?: Dateiname (Standard: response.wav)");
    kg_seed_tool("generate_image", "Generiert ein Bild aus einer Textbeschreibung und sendet es im Chat. Nutze dies wenn der User ein Bild erstellen, zeichnen oder visualisieren lassen moechte.", "prompt: Bildbeschreibung auf Englisch fuer beste Ergebnisse, filename?: Dateiname (Standard: generated.png)");
    kg_seed_tool("add_todo", "Fuegt eine Aufgabe zur Todo-Liste des aktuellen Raums hinzu.", "text: Aufgabenbeschreibung");
