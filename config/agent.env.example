# =============================================================================
# Varg Matrix Agent - Environment Variables
# Copy this file to deploy/.env and adjust values.
# =============================================================================

# --- Server ---
# IP address or domain name of your server
SERVER_NAME=localhost

# --- Matrix ---
# Agent's Matrix credentials (auto-registered on first start)
MATRIX_USERNAME=varg-agent
MATRIX_PASSWORD=changeme

# Agent display name shown in Matrix clients
AGENT_DISPLAY_NAME=Varg Agent

# Auto-join rooms when invited (true/false)
AGENT_AUTO_JOIN=true

# --- LLM Provider ---
# Options: ollama, openai, anthropic, gemini
VARG_LLM_PROVIDER=ollama

# Model name (leave empty for provider default)
# ollama: llama3, openai: gpt-4o, anthropic: claude-sonnet-4-20250514, gemini: gemini-2.0-flash
VARG_LLM_MODEL=

# Override base URL for LLM API (leave empty for default)
VARG_LLM_URL=

# --- API Keys (required for respective providers) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Agent Behavior ---
# Custom system prompt (leave empty for default)
AGENT_SYSTEM_PROMPT=

# --- Federation ---
# Enable Matrix federation with other servers (true/false)
ALLOW_FEDERATION=false

# --- Ports (development mode) ---
CONDUIT_PORT=6167
ELEMENT_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443
