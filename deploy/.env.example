# Varg Agent - Environment Configuration
# Copy this file to .env and edit with your settings:
#   cp .env.example .env

# Matrix Server
SERVER_NAME=localhost

# Agent Account (auto-registered on first start if it doesn't exist)
MATRIX_USERNAME=rose
MATRIX_PASSWORD=ChangeThisPassword!
AGENT_DISPLAY_NAME=Rose

# LLM Provider: gemini, openai, anthropic, ollama
VARG_LLM_PROVIDER=gemini
VARG_LLM_MODEL=gemini-2.0-flash

# API Keys (set the one for your chosen provider)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama URL (local: http://host.docker.internal:11434, cloud: https://api.ollama.com/v1/chat/completions)
VARG_LLM_URL=

# Ports
HTTP_PORT=2077

# Optional
AGENT_SYSTEM_PROMPT=
MATRIX_ROOM_ID=
